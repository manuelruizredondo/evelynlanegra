---
import Base from "../layouts/Base.astro";
import Faq from "../components/Faq.astro";
import { site } from "../data/site";

const faqs = [
  { q: "¿Necesito venir con pareja?", a: "No. En las clases se va rotando, así que puedes apuntarte sola o solo sin problema." },
  { q: "¿Se puede empezar sin nivel previo?", a: "Sí. Hay grupos y contenidos pensados para empezar desde cero; te acompaño desde la pisada y el conteo básico." },
  { q: "¿Dónde son las clases presenciales?", a: `En Barcelona (BS Dance Center) e Ibiza (Davinia Van Praag Dance Academy). Puedes ver horarios en <a href="/clases-presenciales/">clases presenciales</a>.` },
  { q: "¿Las clases online se quedan grabadas?", a: "Sí. Las sesiones en directo por Zoom se graban para que las repases a tu ritmo cuando quieras." },
  { q: "¿El máster sirve para dar clases de bachata tradicional?", a: `Es una formación de profesorado con metodología propia y diploma acreditativo. Tienes el temario en la <a href="/profesora-bachata-dominicana/">página del máster</a>.` },
];

const eventos = [
  { img: "/img/campeonato.webp", chip: "Calpe · Alicante · 21–25 oct", t: "El campeonato mundial",
    d: "El Mundial de Pasos Libres de Salsa: la competición pionera en el mundo, creada por La Negra. Bailarines de todo el planeta en una sola pista.",
    href: site.festival, external: true, cta: "Reserva tu plaza" },
  { img: "/img/crucero.jpg", chip: "España · Italia · Francia · 1–8 nov", t: "Crucero del baile",
    d: "Más que un viaje — días de salsa, bachata y buena compañía a bordo. Clases, sesiones y mar abierto.",
    href: site.whatsapp, external: true, cta: "Reserva tu plaza" },
];

const presenciales = [
  { img: "/img/2024/12/clases-bcn-korke-y-judith-576x1024.jpeg", chip: "Clases regulares · jueves", t: "Barcelona",
    d: "Bachata tradicional en BS Dance Center. Clases regulares en directo todos los jueves.",
    href: "/clases-presenciales/#barcelona", cta: "Ver clases" },
  { img: "/img/2025/11/IBIZA-clases-nov-dic25-con-horarios-819x1024.png", chip: "Clases regulares · todo el año", t: "Ibiza",
    d: "Salsa y bachata en Davinia Van Praag Dance Academy. Cursos regulares por trimestre.",
    href: "/clases-presenciales/#ibiza", cta: "Ver clases" },
];

const online = [
  { img: "/img/2021/10/web-ensenanza-de-la-bachata-libro-1024x1024.jpg", chip: "Programa de profesorado", t: "Máster en Bachata Tradicional",
    d: "Formación reglada para profesores: módulos I, II y III, metodología propia y la titulación de referencia en bachata dominicana.",
    href: "/profesora-bachata-dominicana/", cta: "Ver programa" },
  { img: "/img/2024/12/los-jueves-zoom-1080X1080-1024x1024.png", chip: "En directo · Zoom", t: "Clases online",
    d: "Bachata y salsa en directo por Zoom. Las clases se quedan grabadas para ti.",
    href: "/bachata-salsa-online-offline/", cta: "Empezar" },
];

const worldtour = [
  { mes: "Julio", items: [
    { place: "Japón · Tokio", date: "2 al 5", event: "Bachata Media Japón Festival" },
    { place: "Korea · Jeju Island", date: "10 al 12", event: "K-Sensual 10th Anniversary" },
    { place: "Gran Canaria", date: "17 al 19", event: "Teacher Training e Intensivo Bachata Tradicional I" },
    { place: "Valencia", date: "26 al 27", event: "Teacher Training Bachata Tradicional (I, II y III)" },
    { place: "Italia · Roma", date: "31 al 2", event: "Meeteach Bachata Weekend" },
  ]},
  { mes: "Agosto", items: [
    { place: "Italia · Roma", date: "1 y 2", event: "Meeteach Bachata Weekend" },
    { place: "Rumanía · Bucarest", date: "7 al 9", event: "Formación e Intensivo Bachata Tradicional" },
    { place: "México Tour", date: "19 al 30", event: "Varias ciudades" },
  ]},
  { mes: "Septiembre", items: [
    { place: "Taiwán · Taipei", date: "5 y 6", event: "Freedom Bachata Weekender" },
    { place: "Sevilla", date: "10 al 13", event: "DyD Be Unlike" },
    { place: "Madrid", date: "17 al 20", event: "Vacílalo Madrid Congress" },
    { place: "Quito · Ecuador", date: "24 al 28", event: "República Bachata" },
  ]},
  { mes: "Octubre", items: [
    { place: "Noruega · Oslo", date: "2 al 4", event: "Intensivo Bachata Tradicional" },
    { place: "Ibiza", date: "4 al 9", event: "Dance4two Dance Holiday" },
    { place: "Barcelona", date: "9 al 11", event: "Teacher Training Course by Korke y Judith" },
    { place: "Calpe · Alicante", date: "21 al 25", event: "XV Mundial de Pasos Libres" },
    { place: "Santa Susana", date: "30 al 31", event: "El Bloque Bachatero" },
  ]},
  { mes: "Noviembre", items: [
    { place: "España · Italia · Francia", date: "1 al 8", event: "Crucero del Baile · Edición Delux Otoño" },
    { place: "Italia", date: "14 y 15", event: "Formación e intensivos" },
    { place: "Polonia", date: "19 al 22", event: "Bachateando Afrolatin Dance Festival" },
    { place: "Malasia · Kuala Lumpur", date: "27 al 29", event: "World Bachata Festival Kuala Lumpur" },
  ]},
  { mes: "Diciembre", items: [
    { place: "China", date: "4 al 6", event: "Bachata Congress" },
    { place: "Italia · Treviso", date: "11 al 13", event: "Intensivo Bachata Tradicional #Sinbarrio" },
    { place: "Holanda", date: "18 al 20", event: "Biezenmortel Christmas Edition" },
  ]},
];

// Atenúa (en build) los meses del tour ya pasados. Gira de 2026.
const MES_NUM = { Enero:0, Febrero:1, Marzo:2, Abril:3, Mayo:4, Junio:5, Julio:6, Agosto:7, Septiembre:8, Octubre:9, Noviembre:10, Diciembre:11 };
const TOUR_YEAR = 2026;
const _now = new Date();
const _curYM = _now.getFullYear() * 12 + _now.getMonth();
const isPastMonth = (mes) => TOUR_YEAR * 12 + (MES_NUM[mes] ?? 0) < _curYM;
---
<Base
  title="Évelyn «La Negra» — Profesora & DJ de salsa y bachata dominicana"
  description="Évelyn «La Negra»: profesora y DJ de ritmos latinos desde 1997. Salsa y bachata dominicana en Barcelona, Ibiza y online."
  transparentHeader={true}
  preloadImage="/img/evelynbn.png"
>
  <div class="ln">

    <!-- HERO -->
    <header class="ln-hero">
      <img class="ln-hero__img" src="/img/evelynbn.png" alt="Évelyn «La Negra» bailando bachata dominicana"
        width="1830" height="1025" fetchpriority="high" decoding="async" />
      <h1 class="ln-hero__name">
        <span class="he-name">Évelyn</span>
        <strong class="he-laneg">La Negra</strong>
        <span class="he-disc">Bachata Tradicional</span>
      </h1>
      <div class="ln-hero__bottom container">
        <p class="ln-hero__role">Profesora &amp; DJ · Salsa · Bachata Dominicana</p>
        <div class="ln-hero__cta">
          <a class="btn btn--red btn--lg" href={site.whatsapp} target="_blank" rel="noopener">Ven a bailar</a>
          <a class="btn btn--ghost btn--lg" href="/curriculum/">Conócela</a>
        </div>
      </div>
    </header>

    <!-- FRANJA DE CREDIBILIDAD -->
    <section class="stats" aria-label="La Negra en cifras">
      <div class="container stats__grid">
        <div class="stat"><span class="stat__n">30</span><span class="stat__l">años en la pista</span></div>
        <div class="stat"><span class="stat__n">40+</span><span class="stat__l">países en gira</span></div>
        <div class="stat"><span class="stat__n">2010</span><span class="stat__l">creó el Mundial de Pasos Libres</span></div>
        <div class="stat"><span class="stat__n">∞</span><span class="stat__l">maestra de maestros</span></div>
      </div>
    </section>

    <!-- 1 · EVENTOS -->
    <section class="ev" id="eventos">
      <div class="container">
        <h2 class="ev__title">Próximos eventos</h2>
        <div class="ev__grid">
          {eventos.map((c) => (
            <a class="evcard" href={c.href} {...(c.external ? { target: "_blank", rel: "noopener" } : {})}>
              <img class="evcard__img" src={c.img} alt={c.t} loading="lazy" />
              <span class="evcard__chip">{c.chip}</span>
              <div class="evcard__body">
                <h3>{c.t}</h3>
                <p>{c.d}</p>
                <span class="evcard__link">{c.cta} <span class="arrow">→</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 2 · FORMACIÓN PRESENCIAL -->
    <section class="ev" id="formacion-presencial">
      <div class="container">
        <h2 class="ev__title">Formación presencial</h2>
        <div class="ev__grid">
          {presenciales.map((c) => (
            <a class="evcard" href={c.href}>
              <img class="evcard__img" src={c.img} alt={c.t} loading="lazy" />
              <span class="evcard__chip">{c.chip}</span>
              <div class="evcard__body">
                <h3>{c.t}</h3>
                <p>{c.d}</p>
                <span class="evcard__link">{c.cta} <span class="arrow">→</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 3 · FORMACIÓN ONLINE & MÁSTER -->
    <section class="ev" id="formacion-online">
      <div class="container">
        <h2 class="ev__title">Formación online &amp; Máster</h2>
        <div class="ev__grid">
          {online.map((c) => (
            <a class="evcard" href={c.href}>
              <img class="evcard__img" src={c.img} alt={c.t} loading="lazy" />
              <span class="evcard__chip">{c.chip}</span>
              <div class="evcard__body">
                <h3>{c.t}</h3>
                <p>{c.d}</p>
                <span class="evcard__link">{c.cta} <span class="arrow">→</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 4 · WORLD TOUR -->
    <section class="tour" id="world-tour">
      <div class="container">
        <h2 class="ev__title">World Tour 2026</h2>
        <p class="tour__sub">Ruta La Negra · jul – dic 2026. Encuéntrame por todo el mundo.</p>
      </div>
      <div class="tour__cols">
        {worldtour.map((m) => (
          <div class:list={["tour__month", { "tour__month--past": isPastMonth(m.mes) }]}>
            <h3 class="tour__mes">{m.mes}</h3>
            {m.items.map((it) => (
              <div class="tour__item">
                <p class="tour__place">{it.place} <span class="tour__date">{it.date}</span></p>
                <p class="tour__event">{it.event}</p>
              </div>
            ))}
          </div>
        ))}
      </div>
      <div class="container">
        <p class="tour__note">Domingos · DJ residente KEEPER Ibiza &nbsp;·&nbsp; Clases regulares: Ibiza (lun–mié) · Barcelona BS Dance Center (jueves)</p>
        <p class="tour__cta"><a class="btn btn--red btn--lg" href={site.whatsapp} target="_blank" rel="noopener">Próximas fechas</a></p>
      </div>
    </section>

    <!-- 5 · TIENDA -->
    <section class="ln-merch" id="tienda">
      <div class="container ln-merch__inner">
        <div>
          <p class="kick">Tienda</p>
          <h2 class="ln-h2">Camisetas oficiales</h2>
          <p class="ln-merch__lead">Lleva el Método Bachata Tradicional contigo. Usa el código
            <strong>EVELYN</strong> y consigue un 10% de descuento.</p>
          <a class="btn btn--red btn--lg" href={site.shop} target="_blank" rel="noopener">Ir a la tienda</a>
        </div>
        <div class="ln-merch__imgs">
          <img src="/img/2021/02/CAMISETA-BACHATA-TRADICIONAL-CHICAS.jpg" alt="Camiseta chicas" loading="lazy" />
          <img src="/img/2021/02/CAMISETA-BACHATA-TRADICIONAL-CHICOS.jpg" alt="Camiseta chicos" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- 5b · FAQ -->
    <Faq kicker="Dudas frecuentes" title="Preguntas frecuentes" items={faqs} />

    <!-- 6 · CONTACTA -->
    <section class="ln-social" id="contacta">
      <div class="container ln-social__inner">
        <div>
          <p class="kick">Contacta</p>
          <h2 class="ln-h2">¿Hablamos?</h2>
          <div class="ln-social__links">
            <a href={site.whatsapp} target="_blank" rel="noopener">WhatsApp</a>
            <a href={`tel:${site.phone.replace(/\s/g, "")}`}>Teléfono</a>
            <a href={`mailto:${site.email}`}>Email</a>
          </div>
          <div class="ln-social__links ln-social__links--alt">
            <a href={site.instagram} target="_blank" rel="noopener">Instagram</a>
            <a href={site.spotify} target="_blank" rel="noopener">Spotify</a>
            <a href={site.festival} target="_blank" rel="noopener">LaNegra World Championship</a>
          </div>
        </div>
        <form class="ln-news" name="newsletter" method="POST" action="/gracias/" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="newsletter" />
          <p hidden><label>No rellenar: <input name="bot-field" /></label></p>
          <label class="ln-news__label" for="nl-email">Recibe fechas y novedades</label>
          <div class="ln-news__row">
            <input id="nl-email" type="email" name="email" placeholder="tu@email.com" required />
            <button class="btn btn--red" type="submit">Apúntame</button>
          </div>
          <label class="ln-news__consent">
            <input type="checkbox" name="consentimiento" value="si" required />
            <span>Acepto la <a href="/privacidad/" target="_blank" rel="noopener">política de privacidad</a>.</span>
          </label>
        </form>
      </div>
    </section>

  </div>
</Base>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Event",
      name: "Mundial de Pasos Libres de Salsa",
      description: "La competición pionera de salsa en el mundo, creada por La Negra.",
      startDate: "2026-10-21",
      endDate: "2026-10-25",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      location: { "@type": "Place", name: "Calpe", address: "Calpe, Alicante, España" },
      organizer: { "@type": "Person", name: "Évelyn «La Negra»" },
      url: site.festival,
    },
    {
      "@type": "Event",
      name: "Crucero del Baile · Edición Delux Otoño",
      description: "Días de salsa, bachata y buena compañía a bordo: clases, sesiones y mar abierto.",
      startDate: "2026-11-01",
      endDate: "2026-11-08",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      location: { "@type": "Place", name: "Mediterráneo", address: "España · Italia · Francia" },
      organizer: { "@type": "Person", name: "Évelyn «La Negra»" },
    },
  ],
})} />

<style is:global>
  body:has(.ln){background:#0a0a0a;color:#c9c9cc}
</style>

<style>
  .ln{background:#0a0a0a;color:#c9c9cc;--acc:#ce0306;--acc2:#ffc400;--muted:#c9c9cc;--line:rgba(255,255,255,.1);
    font-family:"Mona Sans","Lato",-apple-system,sans-serif}
  .ln :global(h2),.ln :global(h3){color:#fff;font-family:"Mona Sans","Lato",sans-serif}

  /* Franja de credibilidad */
  .stats{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:#0d0d0d}
  .stats__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;padding:36px 20px;text-align:center}
  .stat{display:flex;flex-direction:column;gap:6px}
  .stat__n{font-family:"Mona Sans","Lato",sans-serif;font-weight:900;font-variation-settings:"wght" 900,"wdth" 120;
    font-size:clamp(2rem,5vw,3.2rem);line-height:1;color:#fff}
  .stat__l{font-size:.82rem;letter-spacing:.04em;color:var(--muted);text-transform:uppercase}
  .stat:nth-child(3) .stat__n{color:var(--acc)}
  @media (max-width:680px){.stats__grid{grid-template-columns:1fr 1fr;gap:26px 12px}}

  /* Consentimiento newsletter */
  .ln-news__consent{display:flex;align-items:flex-start;gap:9px;margin-top:12px;font-size:.8rem;color:var(--muted)}
  .ln-news__consent input{width:auto;margin-top:2px;accent-color:var(--acc)}
  .ln-news__consent a{color:var(--acc)}

  /* Display gigante estilo Lando: Mona Sans pesada y expandida */
  .ln-h2,.ln-quote,.ln-journey__text,.ln-hero__name strong,.ln-split__col h3,.ln-tag__title{
    font-stretch:118%;font-variation-settings:"wght" 850,"wdth" 118}
  .ln-hero__name strong,.ln-tag__title{font-variation-settings:"wght" 900,"wdth" 122}
  .kick{font-size:.72rem;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:var(--acc);margin:0 0 14px;display:flex;align-items:center;gap:10px}
  .ln-h2{font-size:clamp(1.9rem,4.6vw,3.2rem);font-weight:800;text-transform:uppercase;letter-spacing:-.01em;line-height:1;margin:0}
  .hl{color:var(--acc)}
  .ln-sign{font-family:var(--script);text-transform:none;color:var(--acc);font-weight:700}

  /* HERO */
  .ln-hero{position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:space-between;overflow:hidden;background:#0a0a0a}
  .ln-hero__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 28%;
    opacity:.95;animation:heroReveal 1.8s ease both}
  @keyframes heroReveal{from{opacity:0;transform:scale(0.92)}to{opacity:.95;transform:scale(1)}}
  @media (prefers-reduced-motion:reduce){.ln-hero__img{animation:none;opacity:.95}}
  .ln-hero::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.6),rgba(0,0,0,.15) 30%,rgba(0,0,0,.35) 70%,#0a0a0a 100%)}
  .ln-hero__top{position:relative;z-index:2;padding-top:96px}
  .chip{display:inline-flex;align-items:center;gap:9px;background:rgba(0,0,0,.5);border:1px solid var(--line);
    padding:8px 16px;border-radius:999px;font-size:.74rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fff}
  .chip .dot{width:8px;height:8px;border-radius:50%;background:var(--acc2);box-shadow:0 0 0 0 rgba(255,196,0,.6)}
  .ln-hero__name{position:relative;z-index:2;text-align:center;margin:auto 0;line-height:1;padding-inline:18px;transform:translateY(12vh)}
  .ln-hero__name .he-name{display:block;font-family:var(--script);text-transform:none;font-weight:400;
    font-size:clamp(2.2rem,6vw,4.2rem);color:#fff;opacity:1;letter-spacing:0;line-height:1}
  .ln-hero__name .he-laneg{display:block;font-family:"Mona Sans","Lato",sans-serif;
    font-size:clamp(3.5rem,16vw,11rem);font-weight:900;letter-spacing:-.02em;text-transform:uppercase;
    color:#fff;line-height:.86;font-stretch:122%;font-variation-settings:"wght" 900,"wdth" 122;margin:-.03em 0}
  .ln-hero__name .he-disc{display:block;font-family:var(--script);text-transform:none;font-weight:400;
    font-size:clamp(1.4rem,6.5vw,4.8rem);color:var(--acc);opacity:1;letter-spacing:0;line-height:1;max-width:100%}
  .ln-hero__bottom{position:relative;z-index:2;padding-bottom:40px;text-align:center}
  .ln-hero__role{font-size:1rem;letter-spacing:.16em;text-transform:uppercase;color:#fff;margin:0 0 20px}
  .ln-hero__cta{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:22px}
  .ln-hero__next{margin:12px 0 0}

  /* MANIFIESTO */
  .ln-manifesto{padding:110px 0 60px;border-top:1px solid var(--line)}
  .ln-manifesto .kick{justify-content:center;margin-bottom:18px}
  .ln-quote{font-size:clamp(1.7rem,4.4vw,3rem);font-weight:800;line-height:1.12;max-width:20ch;margin:0 auto;text-align:center;text-transform:uppercase;letter-spacing:-.01em}
  .ln-quote em{font-style:normal;color:var(--acc)}
  .ln-quote__sub{color:var(--muted);font-size:1.05rem;margin:22px auto 0;max-width:46ch;text-align:center}
  .hscroll{display:flex;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;padding:46px 24px 14px;scrollbar-width:thin}
  .hscroll__item{flex:0 0 auto;scroll-snap-align:center}
  .hscroll__item img{height:58vh;width:auto;border-radius:14px;object-fit:cover}

  /* JOURNEY */
  .ln-journey{padding:80px 0;border-top:1px solid var(--line)}
  .ln-journey__text{font-size:clamp(1.3rem,3vw,2rem);font-weight:600;line-height:1.4;max-width:24ch;color:#fff;margin:0}
  .ln-journey__text strong{color:var(--acc)}
  .ln-journey__note{color:var(--muted);font-size:1.05rem;line-height:1.6;max-width:54ch;margin:20px 0 0}

  /* SPLIT */
  .ln-split{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--line)}
  .ln-split__col{padding:80px 6vw;text-decoration:none;color:#c9c9cc;transition:background .25s;border-right:1px solid var(--line)}
  .ln-split__col--alt{border-right:0}
  .ln-split__col:hover{background:#121214;text-decoration:none}
  .ln-split__num{font-size:.9rem;font-weight:800;color:var(--acc);letter-spacing:.1em}
  .ln-split__col h3{font-size:clamp(1.8rem,4vw,2.8rem);text-transform:uppercase;font-weight:900;margin:12px 0 12px}
  .ln-split__col p{color:var(--muted);max-width:36ch;margin:0 0 18px}
  .ln-split__go{color:var(--acc);font-weight:700}

  /* SHOWCASE */
  .ln-show{padding:96px 0;border-top:1px solid var(--line)}
  .ln-show__head{margin-bottom:40px}
  .ln-show__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .tile{display:block;text-decoration:none;color:#fff;group:tile}
  .tile__media{aspect-ratio:3/4;overflow:hidden;border-radius:14px;background:#0f0f10;border:1px solid var(--line)}
  .tile__media img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease;filter:grayscale(.2)}
  .tile:hover .tile__media img{transform:scale(1.06);filter:grayscale(0)}
