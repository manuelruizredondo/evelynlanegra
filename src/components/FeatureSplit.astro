---
// Fila: imagen (retrato) + bloque de texto con CTA. Alterna lado con `flip`.
import { site } from "../data/site";
const { image, alt = "", eyebrow, title, lines = [], cta, flip = false, dark = false, showContact = false } = Astro.props;
---
<section class:list={["feature", { "feature--flip": flip, "feature--dark": dark }]}>
  <div class="container feature__inner">
    <div class="feature__media">
      <img src={image} alt={alt} loading="lazy" />
    </div>
    <div class="feature__body">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      {title && <h2 set:html={title} />}
      {lines.map((l) => <p set:html={l} />)}
      {showContact && (
        <div class="feature__contact">
          <p class="feature__phone">
            <a href={`tel:${site.phone.replace(/\s/g, "")}`}>T. {site.phoneShort}</a>
          </p>
          <p class="feature__wa-note">También por WhatsApp</p>
          <a class="feature__wa" href={site.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp">
            <img src="/img/2019/09/whatsUp200PX.png" width="64" height="64" alt="WhatsApp" />
          </a>
        </div>
      )}
      {cta && (
        <p><a class:list={["btn", cta.variant === "blue" ? "" : "btn--red"]} href={cta.href}
          {...(cta.external ? { target: "_blank", rel: "noopener" } : {})}>{cta.label}</a></p>
      )}
      <slot />
    </div>
  </div>
</section>

<style>
  .feature{padding:60px 0}
  .feature--dark{background:#0f0f10;color:#c9c9cc}
  .feature--dark :global(h2){color:#fff}
  .feature__inner{display:grid;grid-template-columns:minmax(0,0.9fr) 1.1fr;gap:48px;align-items:center}
  .feature--flip .feature__media{order:2}
  .feature__media img{width:100%;border-radius:12px;box-shadow:0 14px 40px rgba(0,0,0,.18)}
  .feature__body h2{font-size:1.7rem}
  .feature__contact{margin:22px 0 8px}
  .feature__phone{font-size:1.6rem;font-weight:700;margin:0 0 .15em}
  .feature__phone a{color:inherit;text-decoration:none}
  .feature__phone a:hover{text-decoration:underline}
  .feature__wa-note{margin:0 0 10px;font-size:.95rem}
  .feature__wa{display:inline-block}
  .feature--dark .feature__phone a{color:#fff}
  @media (max-width:820px){
    .feature__inner{grid-template-columns:1fr;gap:24px;text-align:center}
    .feature--flip .feature__media{order:0}
    .feature__media{max-width:420px;margin-inline:auto}
  }
</style>
