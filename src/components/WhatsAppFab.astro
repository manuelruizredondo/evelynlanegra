---
// Botón flotante de WhatsApp — CTA de conversión siempre visible.
import { site } from "../data/site";
import { getLocale, ui } from "../i18n";
const t = ui[getLocale(Astro.url)];
const href = `${site.whatsapp}?text=${encodeURIComponent(t.wa)}`;
---
<a class="wa-fab" href={href} target="_blank" rel="noopener" aria-label={t.waLabel}>
  <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
    <path fill="currentColor" d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.207zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.767.967-.94 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
  </svg>
</a>

<style>
  .wa-fab{
    position:fixed;right:20px;bottom:20px;z-index:900;
    width:58px;height:58px;border-radius:50%;
    display:grid;place-items:center;color:#fff;background:#25d366;
    box-shadow:0 8px 24px rgba(0,0,0,.35);text-decoration:none;
    transition:transform .2s ease,box-shadow .2s ease;
    animation:wa-in .4s ease both .8s;
  }
  .wa-fab:hover{transform:scale(1.08);box-shadow:0 10px 30px rgba(0,0,0,.45);text-decoration:none}
  .wa-fab::after{content:"";position:absolute;inset:0;border-radius:50%;
    box-shadow:0 0 0 0 rgba(37,211,102,.5);animation:wa-pulse 2.6s ease-out infinite}
  @keyframes wa-pulse{0%{box-shadow:0 0 0 0 rgba(37,211,102,.45)}70%{box-shadow:0 0 0 16px rgba(37,211,102,0)}100%{box-shadow:0 0 0 0 rgba(37,211,102,0)}}
  @keyframes wa-in{from{opacity:0;transform:scale(.6)}to{opacity:1;transform:scale(1)}}
  @media (max-width:600px){.wa-fab{right:16px;bottom:16px;width:54px;height:54px}}
  @media (prefers-reduced-motion:reduce){.wa-fab,.wa-fab::after{animation:none}}
</style>
