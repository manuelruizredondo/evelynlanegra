---
import Base from "../../layouts/Base.astro";
import PageIntro from "../../components/PageIntro.astro";
const logos = [
  { src: "/img/2021/02/metodo-la-negra-bachata-tradicional-blanco-1024x1024.jpg", label: "Método La Negra · Bachata Tradizionale" },
  { src: "/img/2021/02/la-negra-logo-fondos-claros.jpg", label: "La Negra · logo (sfondi chiari)" },
  { src: "/img/2021/02/JPG-mundial-pasos-libres.jpg", label: "Mundial de Pasos Libres" },
  { src: "/img/2022/10/MUNDIAL-BACHATA-generico.jpg", label: "Mundial de Bachata Tradicional" },
  { src: "/img/2022/10/MUNDIAL-PASOS-LIBRES-generico.jpg", label: "Mundial de Pasos Libres (generico)" },
];
---
<Base title="Loghi · La Negra" description="Scarica i loghi ufficiali del Método La Negra, Mundial de Pasos Libres e Mundial de Bachata Tradicional.">
  <PageIntro
    kicker="Brand · Download"
    title="I <em>loghi</em> di La Negra."
    lead={[
      "Scarica il logo del Método La Negra · Bachata Tradizionale e gli altri elementi grafici.",
      "Disponibili in EPS, JPG, PDF e PNG.",
    ]}
    cue="Download"
  />

  <section class="section">
    <div class="container">
      <h2 class="text-center">Logo Método La Negra · Bachata Tradizionale</h2>
      <p class="text-center" style="max-width:640px;margin:0 auto 8px">
        Compila il modulo e ti invierò un'email con un link per scaricare il logo. Potrai
        scaricare uno ZIP con il logo in formato EPS, JPG, PDF e PNG. Se non lo ricevi, controlla la
        cartella spam.</p>

      <form name="logotipos-it" method="POST" action="/it/gracias/" data-netlify="true" netlify-honeypot="bot-field" class="cform">
        <input type="hidden" name="form-name" value="logotipos-it" />
        <p hidden><label>No rellenar: <input name="bot-field" /></label></p>
        <label>Nome<input type="text" name="nombre" required /></label>
        <label>Email<input type="email" name="email" required /></label>
        <label class="cform__consent">
          <input type="checkbox" name="consentimiento" value="si" required />
          <span>Accetto l'<a href="/it/privacidad/" target="_blank" rel="noopener">informativa sulla privacy</a>.</span>
        </label>
        <button class="btn btn--red btn--lg" type="submit">Voglio il logo</button>
      </form>

      <h2 class="text-center" style="margin-top:60px">Altri elementi grafici</h2>
      <div class="logo-grid">
        {logos.map((l) => (
          <figure class="logo-card">
            <img src={l.src} alt={l.label} loading="lazy" />
            <figcaption>{l.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .gallery-hero{background:#0f0f10;color:#fff;padding:90px 0 50px}
  .gallery-hero h1{color:#fff;font-size:2.6rem}
  .cform{display:grid;gap:16px;max-width:520px;margin:22px auto 0}
  .cform label{display:flex;flex-direction:column;gap:6px;font-weight:700;color:#fff;font-size:.78rem;
    text-transform:uppercase;letter-spacing:.05em}
  .cform input{font:inherit;font-weight:400;padding:13px 16px;border:1px solid var(--line);border-radius:10px;
    background:var(--bg2);color:#fff}
  .cform input:focus{outline:none;border-color:var(--acc)}
  .cform button{justify-self:center;border:0}
  .cform__consent{flex-direction:row;align-items:flex-start;gap:10px;text-transform:none;letter-spacing:0;
    font-weight:400;font-size:.85rem;color:var(--text)}
  .cform__consent input{width:auto;margin-top:2px;accent-color:var(--acc)}
  .cform__consent a{color:var(--acc)}
  .logo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:20px;margin-top:24px}
  .logo-card{margin:0;text-align:center}
  .logo-card img{width:100%;border:1px solid var(--line);border-radius:10px;background:#fff}
  .logo-card figcaption{font-size:.82rem;margin-top:8px;color:var(--text);font-weight:700}
</style>
