---
import Base from "../layouts/Base.astro";
const logos = [
  { src: "/img/2021/02/metodo-la-negra-bachata-tradicional-blanco-1024x1024.jpg", label: "Método La Negra · Bachata Tradicional" },
  { src: "/img/2021/02/la-negra-logo-fondos-claros.jpg", label: "La Negra · logo (fondos claros)" },
  { src: "/img/2021/02/JPG-mundial-pasos-libres.jpg", label: "Mundial de Pasos Libres" },
  { src: "/img/2022/10/MUNDIAL-BACHATA-generico.jpg", label: "Mundial de Bachata Tradicional" },
  { src: "/img/2022/10/MUNDIAL-PASOS-LIBRES-generico.jpg", label: "Mundial de Pasos Libres (genérico)" },
];
---
<Base title="Logotipos · La Negra" description="Descarga los logotipos oficiales del Método La Negra, Mundial de Pasos Libres y Mundial de Bachata Tradicional.">
  <section class="gallery-hero">
    <div class="container text-center">
      <p class="eyebrow" style="color:var(--red-bright)">Descargas</p>
      <h1>Logotipos</h1>
      <p style="opacity:.85;max-width:600px;margin:10px auto 0">Logotipo del Método La Negra · Bachata Tradicional y otros elementos gráficos descargables.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="text-center">Logo Método La Negra · Bachata Tradicional</h2>
      <p class="text-center" style="max-width:640px;margin:0 auto 8px">
        Rellena el formulario y te enviaré un email con un enlace para descargar el logotipo. Podrás
        descargar un ZIP con el logotipo en formato EPS, JPG, PDF y PNG. Si no lo recibes, revisa tu
        carpeta de spam.</p>

      <form name="logotipos" method="POST" action="/gracias/" data-netlify="true" netlify-honeypot="bot-field" class="cform">
        <input type="hidden" name="form-name" value="logotipos" />
        <p hidden><label>No rellenar: <input name="bot-field" /></label></p>
        <label>Nombre<input type="text" name="nombre" required /></label>
        <label>Email<input type="email" name="email" required /></label>
        <button class="btn btn--red btn--lg" type="submit">Quiero el logotipo</button>
      </form>

      <h2 class="text-center" style="margin-top:60px">Otros elementos gráficos</h2>
      <div class="logo-grid">
        {logos.map((l) => (
          <figure class="logo-card">
            <img src={l.src} alt={l.label} loading="lazy" />
            <figcaption>{l.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .gallery-hero{background:#111;color:#fff;padding:90px 0 50px}
  .gallery-hero h1{color:#fff;font-size:2.6rem}
  .cform{display:grid;gap:16px;max-width:520px;margin:22px auto 0}
  .cform label{display:flex;flex-direction:column;gap:6px;font-weight:700;color:var(--ink);font-size:.85rem}
  .cform input{font:inherit;font-weight:400;padding:12px 14px;border:1px solid #ddd;border-radius:8px}
  .cform button{justify-self:center;border:0}
  .logo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:20px;margin-top:24px}
  .logo-card{margin:0;text-align:center}
  .logo-card img{width:100%;border:1px solid #eee;border-radius:10px;background:#fff}
  .logo-card figcaption{font-size:.82rem;margin-top:8px;color:var(--ink);font-weight:700}
</style>
