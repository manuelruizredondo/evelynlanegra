---
import Base from "../../layouts/Base.astro";
import PageIntro from "../../components/PageIntro.astro";
import { site } from "../../data/site";

// Mis TOP 10 mensuales. Pega el enlace de cada lista de Spotify en `embed`
// (Spotify → ··· → Compartir → Copiar enlace de la lista). En cuanto haya un
// enlace, esa lista se reproduce dentro de la web al pulsarla.
const tops = [
  { mes: "Estate 2023", cover: "/img/2023/08/top10-musica-verano-salsa-bachata-merengue-260x300.jpg", embed: "" },
  { mes: "Maggio 2022", cover: "/img/2022/05/top10-musica-mayo-salsa-bachata-merengue-260x300.jpg", embed: "" },
  { mes: "Aprile 2022", cover: "/img/2022/04/top10-musica-abril-salsa-bachata-merengue-260x300.jpg", embed: "" },
  { mes: "Marzo 2022", cover: "/img/2022/03/top10-musica-marzo-salsa-bachata-merengue-260x300.jpg", embed: "" },
  { mes: "Febbraio 2022", cover: "/img/2022/02/top10-musica-febrero-salsa-bachata-merengue-260x300.jpg", embed: "" },
  { mes: "Gennaio 2022", cover: "/img/2022/01/top10-musica-enero-salsa-bachata-merengue-260x300.jpg", embed: "" },
  { mes: "Dicembre 2021", cover: "/img/2021/12/top10-musica-diciembre-salsa-bachata-merengue-260x300.jpg", embed: "" },
  { mes: "Novembre 2021", cover: "/img/2021/11/top10-musica-noviembre-salsa-bachata-merengue-260x300.jpg", embed: "" },
  { mes: "Ottobre 2021", cover: "/img/2021/10/top10-musica-octubre-salsa-bachata-merengue-2-260x300.jpg", embed: "" },
  { mes: "Settembre 2021", cover: "/img/2021/09/top10-musica-septiembre-salsa-bachata-merengue-1-260x300.jpg", embed: "" },
];

const playlistId = (url) => (/playlist\/([A-Za-z0-9]+)/.exec(url || "") || [])[1] || "";
const firstWithEmbed = tops.find((t) => playlistId(t.embed));
---
<Base
  title="I miei TOP 10 su Spotify · Salsa, Bachata e Merengue · La Negra"
  description="Le liste TOP 10 di Évelyn La Negra su Spotify: salsa, bachata e merengue per riempire la pista, mese dopo mese. Ascoltale senza uscire dal sito."
>
  <PageIntro
    kicker="Spotify"
    title="I miei <em>TOP 10</em> su Spotify."
    lead={[
      "Ogni mese, la mia selezione di salsa, bachata e merengue per riempire la pista.",
      `Scegli un mese e parte qui, oppure <a href="${site.spotify}" target="_blank" rel="noopener">seguimi su Spotify</a>.`,
    ]}
    cue="Il jukebox"
  />

  <section class="jukebox">
    <div class="container jukebox__inner">
      <!-- Reproductor -->
      <div class="jukebox__player" data-player data-default-id={firstWithEmbed ? playlistId(firstWithEmbed.embed) : ""}>
        <div class="jukebox__placeholder">
          <span class="jukebox__note">▶</span>
          <p>Scegli una lista del mese e fai partire la musica</p>
          <a class="btn btn--red" href={site.spotify} target="_blank" rel="noopener">Apri su Spotify</a>
        </div>
      </div>

      <!-- Lista de meses -->
      <div class="jukebox__list" role="list" aria-label="Liste per mese">
        {tops.map((t, i) => (
          <button class="track" role="listitem" data-track data-id={playlistId(t.embed)}
            data-fallback={site.spotify} aria-label={`TOP 10 · ${t.mes}`}>
            <img class="track__cover" src={t.cover} alt="" loading="lazy" />
            <span class="track__meta">
              <span class="track__n">{String(i + 1).padStart(2, "0")}</span>
              <span class="track__mes">{t.mes}</span>
            </span>
            <span class="track__play" aria-hidden="true">▶</span>
          </button>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .jukebox{padding:14px 0 96px}
  .jukebox__inner{display:grid;grid-template-columns:1.25fr 1fr;gap:28px;align-items:start}

  /* Reproductor */
  .jukebox__player{position:sticky;top:130px;border-radius:16px;overflow:hidden;
    border:1px solid var(--line);background:var(--bg2);min-height:420px;display:flex}
  .jukebox__player iframe{width:100%;height:520px;border:0;display:block}
  .jukebox__placeholder{margin:auto;text-align:center;padding:40px;color:var(--muted)}
  .jukebox__note{display:grid;place-items:center;width:62px;height:62px;margin:0 auto 18px;
    border-radius:50%;background:#1db954;color:#000;font-size:1.2rem}
  .jukebox__placeholder p{color:#fff;font-size:1.1rem;margin:0 0 20px}

  /* Lista */
  .jukebox__list{display:flex;flex-direction:column;gap:8px;max-height:560px;overflow-y:auto;padding-right:4px}
  .track{display:flex;align-items:center;gap:16px;width:100%;text-align:left;cursor:pointer;
    background:transparent;border:1px solid transparent;border-radius:12px;padding:10px 12px;
    color:#fff;transition:background .2s,border-color .2s}
  .track:hover{background:var(--bg2);border-color:var(--line)}
  .track.is-active{background:var(--bg2);border-color:var(--acc)}
  .track__cover{width:56px;height:56px;border-radius:8px;object-fit:cover;flex:0 0 auto}
  .track__meta{display:flex;flex-direction:column;gap:2px;flex:1;min-width:0}
  .track__n{font-size:.7rem;font-weight:700;letter-spacing:.1em;color:var(--acc)}
  .track__mes{font-weight:600;font-size:1rem}
  .track__play{display:grid;place-items:center;width:34px;height:34px;border-radius:50%;
    border:1px solid var(--line);color:#fff;font-size:.7rem;flex:0 0 auto;transition:background .2s,border-color .2s}
  .track:hover .track__play,.track.is-active .track__play{background:#1db954;border-color:#1db954;color:#000}

  @media (max-width:860px){
    .jukebox__inner{grid-template-columns:1fr}
    .jukebox__player{position:static;min-height:0}
    .jukebox__player iframe{height:380px}
    .jukebox__list{max-height:none}
  }
</style>

<script>
  const player = document.querySelector("[data-player]") as HTMLElement | null;
  const tracks = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-track]"));

  function play(id: string, btn: HTMLButtonElement) {
    if (!player) return;
    player.innerHTML =
      `<iframe src="https://open.spotify.com/embed/playlist/${id}?theme=0" ` +
      `loading="lazy" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" ` +
      `title="Lista de Spotify"></iframe>`;
    tracks.forEach((t) => t.classList.remove("is-active"));
    btn.classList.add("is-active");
    player.scrollIntoView({ block: "nearest", behavior: "smooth" });
  }

  tracks.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.dataset.id;
      if (id) play(id, btn);
      else window.open(btn.dataset.fallback || "https://open.spotify.com", "_blank");
    });
  });

  // Carga inicial: primera lista con enlace disponible
  const defaultId = player?.dataset.defaultId;
  if (defaultId) {
    const first = tracks.find((t) => t.dataset.id === defaultId) || tracks[0];
    if (first) play(defaultId, first);
  }
</script>
