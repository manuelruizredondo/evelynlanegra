---
import Base from "../../layouts/Base.astro";
import PageIntro from "../../components/PageIntro.astro";
import ContactForm from "../../components/ContactForm.astro";
import { site } from "../../data/site";
const wa = "https://api.whatsapp.com/send?phone=34659090696&text=Ciao%20Evelyn,%20vorrei%20info%20sulla%20formazione%20di%20Bachata%20Tradizionale";

const clases = [
  { n: "01", title: "Storia", meta: "2h · Teorica", d: "Accezioni del termine bachata, i precursori e i ritmi che l'hanno originata, origine ed evoluzione della bachata." },
  { n: "02", title: "Musicalità", meta: "2h · Teorica", d: "Linguaggio musicale di base (battito, ritmo, tempo, tempo musicale), l'importanza dei pattern ritmici e degli strumenti." },
  { n: "03", title: "Scomponendo il basico", meta: "2h · Pratica", d: "Differenze tra la bachata autentica, quella moderna e quella sensual. Elementi per ottenere uno stile: appoggio del passo e conteggio." },
  { n: "04", title: "Combinazioni e variazioni", meta: "2h · Pratica", d: "Sistema lineare, quadrato e diagonale. Passi di base e la loro musicalità. Il patín come risorsa." },
  { n: "05", title: "Ballo di coppia", meta: "2h+1 · Teorico-pratica", d: "L'importanza delle braccia e della guida. La «dominicana» da competizione e nel sociale." },
];

const testimonios = [
  { img: "/img/2021/02/Jose-Luis-Chaves.jpg", name: "José Luis Chaves", sub: "de Chaves y Silvia", text: "Non importa quale stile balli… questo corso ti sarà utile di sicuro. Non è solo che già conosci il tradizionale: impari anche a respirare e a sentire la musica." },
  { img: "/img/2021/02/Judith-Cordero-Pereiro.jpg", name: "Judith Cordero Pereiro", sub: "", text: "Felici noi di poter continuare a conoscere le radici e che tu renda tutto così facile. Ascoltarti è rimanere incantati." },
  { img: "/img/2021/02/Gigi-Bellomo.jpg", name: "Gigi Bellomo", sub: "", text: "Grazie a questa esperienza posso dire che ci sono poche persone al mondo che amano ciò che fanno come te." },
  { img: "/img/2021/02/Sylvia-Pires.jpg", name: "Sylvia Pires", sub: "", text: "Carisma, ricerca della perfezione, grinta, umorismo, intelligenza, amore e passione per ciò che fai." },
  { img: "/img/2021/02/Yaimelys-Sonylus.jpg", name: "Yaimelys Sonylus", sub: "", text: "Ho fatto la 1ª formazione con questa grande maestra e sto già facendo la 2ª. È, senza dubbio, una maestra di maestri." },
];
---
<Base
  title="Formazione · Insegnante di Bachata Dominicana · La Negra"
  description="Specializzata in bachata dominicana come DJ, ricercatrice, conferenziera e insegnante. Maestra di maestri. Formazione integrale per insegnanti."
  transparentHeader={true}
>
  <PageIntro
    kicker="Master in Bachata Tradizionale"
    title="Diventa <em>insegnante</em> di bachata dominicana."
    lead={[
      "Formazione strutturata con metodologia propria: la certificazione di riferimento nella bachata tradizionale.",
      "Maestra di maestri — oltre due decenni a insegnare partendo dalle radici.",
    ]}
    cue="Il programma"
  />

  <section class="section">
    <div class="container prose">
      <h2>Bachata Tradizionale 1 e 2</h2>
      <p><strong>Include diploma di attestazione</strong> + dossier di 50 pagine di contenuto originale.</p>
      <h3>Descrizione</h3>
      <p>Lezioni online (10 ore) tramite piattaforma Zoom, dossier di 50 pagine di contenuto originale e
        correzioni individuali.</p>

      <h3>Programma</h3>
      <ol class="syllabus">
        {clases.map((c) => (
          <li class="syllabus__item">
            <span class="syllabus__num">{c.n}</span>
            <div class="syllabus__body">
              <div class="syllabus__head">
                <h4>{c.title}</h4>
                <span class="syllabus__meta">{c.meta}</span>
              </div>
              <p>{c.d}</p>
            </div>
          </li>
        ))}
      </ol>

      <h3>Orario</h3>
      <p>5 settimane: due ore settimanali continuative. Mattine o mezzogiorni a scelta tra mercoledì,
        giovedì o domenica (secondo la richiesta). Potrebbero aprirsi altri orari in base alla richiesta.</p>

      <h3>Avvertenza</h3>
      <p>Questo non è un titolo che ti trasforma in insegnante (se entri nel corso è perché lo sei già).
        Il diploma è un <strong>Certificato di Abilitazione</strong> specifico che viene rilasciato per aver
        superato con alto rendimento il programma «Insegnamento della Bachata Dominicana».</p>
    </div>
  </section>

  <section class="section" style="background:#0f0f10;color:#fff">
    <div class="container">
      <h2 class="text-center" style="color:#fff">Testimonianze</h2>
      <p class="text-center" style="opacity:.8">Leggi cosa dicono di me</p>
    </div>
    <div class="tswiper" data-tswiper>
      <div class="tswiper__track">
        {testimonios.map((t) => (
          <figure class="tcard">
            <img class="tcard__img" src={t.img} alt={t.name} loading="lazy" />
            <div class="tcard__body">
              <blockquote>«{t.text}»</blockquote>
              <figcaption><strong>{t.name}</strong>{t.sub && <span> · {t.sub}</span>}</figcaption>
            </div>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <ContactForm name="contacto-formacion-it" title="Maggiori informazioni" note="Contattami per ricevere maggiori informazioni su questo corso e sulle prossime attività." />
</Base>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Course",
  name: "Master in Bachata Tradizionale — Insegnamento della Bachata Dominicana",
  description: "Formazione per insegnanti di bachata dominicana con metodologia propria, dossier di 50 pagine e diploma di attestazione. Bachata Tradizionale 1 e 2, lezioni online tramite Zoom.",
  provider: { "@type": ["Organization", "DanceSchool"], name: "La Negra Salsa", sameAs: site.instagram },
  inLanguage: "it",
  courseMode: "online",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5",
    reviewCount: String(testimonios.length),
    bestRating: "5",
  },
  review: testimonios.map((t) => ({
    "@type": "Review",
    author: { "@type": "Person", name: t.name },
    reviewRating: { "@type": "Rating", ratingValue: "5", bestRating: "5" },
    reviewBody: t.text,
  })),
})} />

<style>
  .syllabus{list-style:none;margin:18px 0 0;padding:0;border-top:1px solid var(--line)}
  .syllabus__item{display:grid;grid-template-columns:auto 1fr;gap:30px;padding:26px 4px;
    border-bottom:1px solid var(--line);align-items:start;transition:background .2s}
  .syllabus__item:hover{background:rgba(255,255,255,.02)}
  .syllabus__num{font-family:var(--serif);font-style:italic;font-weight:500;font-size:2.6rem;
    line-height:.9;color:var(--acc);min-width:1.4em}
  .syllabus__head{display:flex;align-items:baseline;gap:14px;flex-wrap:wrap;margin-bottom:7px}
  .syllabus__head h4{margin:0;font-size:1.3rem;color:#fff;font-weight:700}
  .syllabus__meta{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;
    color:var(--muted);border:1px solid var(--line);padding:4px 11px;border-radius:999px;white-space:nowrap}
  .syllabus__body p{margin:0;color:var(--text);max-width:62ch;line-height:1.55}
  @media (max-width:600px){
    .syllabus__item{grid-template-columns:1fr;gap:6px;padding:22px 4px}
    .syllabus__num{font-size:1.9rem}
  }
  /* Swiper de testimonios (scroll-snap nativo + autoavance lento) */
  .tswiper{margin-top:38px;overflow:hidden}
  .tswiper__track{display:flex;gap:26px;overflow-x:auto;scroll-snap-type:x mandatory;
    padding:6px clamp(20px,8vw,140px);scroll-padding-inline:clamp(20px,8vw,140px);
    scrollbar-width:none;-ms-overflow-style:none;-webkit-overflow-scrolling:touch}
  .tswiper__track::-webkit-scrollbar{display:none}
  .tcard{margin:0;flex:0 0 clamp(300px,72vw,640px);scroll-snap-align:center;
    display:grid;grid-template-columns:auto 1fr;gap:28px;align-items:center;text-align:left;
    background:rgba(255,255,255,.03);border:1px solid var(--line);border-radius:18px;padding:30px 34px}
  .tcard__img{width:116px;height:116px;border-radius:50%;object-fit:cover;flex-shrink:0}
  .tcard__body{min-width:0}
  .tcard blockquote{margin:0 0 14px;font-style:italic;color:#c9c9cc;font-size:1.02rem;line-height:1.5}
  .tcard figcaption{color:var(--acc);font-size:.9rem;font-weight:700}
  .tcard figcaption span{color:#c9c9cc;font-weight:400}
  @media (max-width:600px){
    .tcard{grid-template-columns:1fr;gap:16px;text-align:center;padding:26px 22px}
    .tcard__img{margin:0 auto}
  }
</style>

<script>
  // Autoavance lento del swiper de testimonios (scroll-snap nativo, pausable)
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  document.querySelectorAll<HTMLElement>("[data-tswiper]").forEach((root) => {
    const track = root.querySelector<HTMLElement>(".tswiper__track");
    if (!track) return;
    const cards = Array.from(track.children) as HTMLElement[];
    if (cards.length < 2 || reduce) return;

    let i = 0;
    let paused = false;
    const go = (n: number) => {
      i = (n + cards.length) % cards.length;
      const card = cards[i];
      const left = card.offsetLeft - (track.clientWidth - card.clientWidth) / 2;
      track.scrollTo({ left, behavior: "smooth" });
    };

    // Sincroniza el índice si el usuario arrastra manualmente
    let syncTimer: number | undefined;
    track.addEventListener("scroll", () => {
      window.clearTimeout(syncTimer);
      syncTimer = window.setTimeout(() => {
        const center = track.scrollLeft + track.clientWidth / 2;
        let best = 0, dist = Infinity;
        cards.forEach((c, idx) => {
          const cc = c.offsetLeft + c.clientWidth / 2;
          const d = Math.abs(cc - center);
          if (d < dist) { dist = d; best = idx; }
        });
        i = best;
      }, 120);
    }, { passive: true });

    const pause = () => { paused = true; };
    const resume = () => { paused = false; };
    root.addEventListener("mouseenter", pause);
    root.addEventListener("mouseleave", resume);
    root.addEventListener("pointerdown", pause);
    root.addEventListener("pointerup", resume);
    root.addEventListener("focusin", pause);
    root.addEventListener("focusout", resume);

    window.setInterval(() => { if (!paused) go(i + 1); }, 4800);
  });
</script>
