---
import Base from "../layouts/Base.astro";
import PageIntro from "../components/PageIntro.astro";
import ContactForm from "../components/ContactForm.astro";
import { site } from "../data/site";

type Clase = { hora: string; estilo: string; nivel?: string };
type Ciudad = {
  id: string; name: string; sub: string; image: string; alt: string; flip: boolean;
  intro: string; academy: string; address: string; price: string;
  dias: { dia: string; clases: Clase[] }[];
};

// Misma estructura para las dos ciudades; `flip` pone la imagen a la derecha (Ibiza).
const ciudades: Ciudad[] = [
  {
    id: "barcelona",
    name: "Barcelona",
    sub: "Bachata tradicional, los jueves",
    image: "/img/2024/12/clases-bcn-korke-y-judith-576x1024.jpeg",
    alt: "Clases de bachata en Barcelona",
    flip: false,
    intro: "Évelyn «La Negra» —DJ, organizadora, periodista y profesora— lleva más de dos décadas enseñando salsa y bachata tradicional en Barcelona. Aprende a bailar desde la raíz, divirtiéndote.",
    academy: "BS Dance Center",
    address: "Carrer de Josep Royo 26 · Santa Adrià de Besòs",
    price: "25 €/mes",
    dias: [
      { dia: "Jueves", clases: [{ hora: "20:30", estilo: "Bachata Tradicional", nivel: "todos los niveles" }] },
    ],
  },
  {
    id: "ibiza",
    name: "Ibiza",
    sub: "Salsa, bachata y rueda, de lunes a miércoles",
    image: "/img/evelyn.png",
    alt: "Clases de salsa y bachata en Ibiza con Évelyn La Negra",
    flip: true,
    intro: "Cinco niveles cada tarde, desde cero hasta avanzado. Y los domingos, DJ residente de la sesión Keeper en la isla.",
    academy: "Davinia Van Praag Dance Academy",
    address: "Calle Sa Real, 1 · Ibiza",
    price: "desde 30 €/mes",
    dias: [
      { dia: "Lunes", clases: [
        { hora: "18:30", estilo: "Salsa", nivel: "medio" },
        { hora: "19:30", estilo: "Bachata", nivel: "medio/bajo" },
        { hora: "20:30", estilo: "Rueda de Casino", nivel: "medio/alto" },
        { hora: "21:30", estilo: "Salsa", nivel: "medio/alto" },
        { hora: "22:30", estilo: "Bachata", nivel: "medio" },
      ]},
      { dia: "Martes", clases: [
        { hora: "18:30", estilo: "Salsa", nivel: "avanzado" },
        { hora: "19:30", estilo: "Bachata", nivel: "medio" },
        { hora: "20:30", estilo: "Expresión Corporal" },
        { hora: "21:30", estilo: "Salsa", nivel: "medio/bajo" },
        { hora: "22:30", estilo: "Bachata", nivel: "medio/bajo" },
      ]},
      { dia: "Miércoles", clases: [
        { hora: "18:30", estilo: "Salsa", nivel: "básico II" },
        { hora: "19:30", estilo: "Bachata", nivel: "básico II" },
        { hora: "20:30", estilo: "Salsa", nivel: "desde cero" },
        { hora: "21:30", estilo: "Bachata", nivel: "desde cero" },
      ]},
    ],
  },
];

// Enlace a Google Maps a partir del nombre del local + dirección.
const mapsUrl = (c: Ciudad) =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${c.academy}, ${c.address.replace(/ · /g, ", ")}`)}`;
---
<Base
  title="Clases presenciales de salsa y bachata en Barcelona e Ibiza · La Negra"
  description="Clases presenciales de salsa y bachata dominicana con Évelyn «La Negra»: los jueves en Barcelona (BS Dance Center) y de lunes a miércoles en Ibiza."
  transparentHeader={true}
>
  <PageIntro
    kicker="Clases presenciales"
    title="Aprende a bailar en <em>Barcelona</em> e <em>Ibiza</em>."
    lead={[
      "Salsa y bachata tradicional, desde cero hasta avanzado.",
      "Clases regulares cada semana — bachata desde la raíz, divirtiéndote.",
    ]}
    cue="Barcelona e Ibiza"
  />

  {ciudades.map((c) => (
    <section id={c.id} class="city">
      <div class="container">
        <h2 class="city-title">{c.name}</h2>
        <p class="city-sub">{c.sub}</p>

        <div class:list={["city__lead", { "city__lead--flip": c.flip }]}>
          <div class="city__media"><img src={c.image} alt={c.alt} loading="lazy" /></div>
          <div class="city__info">
            <p class="city__intro">{c.intro}</p>
            <dl class="city__facts">
              <div><dt>Dónde</dt><dd>
                <a class="maps-link" href={mapsUrl(c)} target="_blank" rel="noopener">
                  {c.academy}<br>{c.address}
                  <span class="maps-link__cta">
                    <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true"><path fill="currentColor" d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
                    Cómo llegar
                  </span>
                </a>
              </dd></div>
              <div><dt>Precio</dt><dd>{c.price}</dd></div>
            </dl>
            <a class="btn btn--red btn--lg" href={site.whatsapp} target="_blank" rel="noopener">Reservar plaza</a>
          </div>
        </div>

        <div class="city__sched">
          {c.dias.map(({ dia, clases }) => (
            <div class="day-card">
              <h3 class="day-card__name">{dia}</h3>
              <ul class="day-card__list">
                {clases.map((cl) => (
                  <li>
                    <span class="day-card__time">{cl.hora}h</span>
                    <span class="day-card__style">{cl.estilo}</span>
                    {cl.nivel && <span class="day-card__level">{cl.nivel}</span>}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <ContactForm name="contacto-presencial" title="Reserva tu plaza"
    note="Dime ciudad y nivel y te confirmo horarios, precios y plaza disponible." />
</Base>

<style>
  .city{padding:64px 0}
  .city + .city{border-top:1px solid var(--line)}

  .city-title{font-family:"Mona Sans","Lato",sans-serif;font-weight:900;
    font-size:clamp(2.6rem,7vw,5rem);letter-spacing:-.015em;text-transform:uppercase;color:#fff;
    line-height:.9;font-stretch:122%;font-variation-settings:"wght" 900,"wdth" 122;margin:0 0 6px}
  .city-sub{font-size:clamp(1.1rem,2.2vw,1.5rem);color:var(--muted);font-weight:600;margin:0}

  /* Fila: imagen + intro (imagen alterna de lado con --flip) */
  .city__lead{display:grid;grid-template-columns:0.82fr 1fr;gap:46px;align-items:center;margin:30px 0 36px}
  .city__lead--flip .city__media{order:2}
  .city__media img{width:100%;aspect-ratio:4/5;object-fit:cover;border-radius:16px;
    border:1px solid var(--line);box-shadow:0 16px 40px rgba(0,0,0,.35)}
  .city__intro{color:var(--text);font-size:1.05rem;line-height:1.6;margin:0 0 24px;max-width:52ch}
  .city__facts{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin:0 0 26px}
  .city__facts dt{font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--acc);font-weight:700;margin-bottom:5px}
  .city__facts dd{margin:0;color:#fff;font-size:.95rem;line-height:1.45}
  .maps-link{color:#fff;text-decoration:none;display:inline-block}
  .maps-link:hover{color:var(--acc);text-decoration:none}
  .maps-link__cta{display:inline-flex;align-items:center;gap:5px;margin-top:6px;
    color:var(--acc);font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em}
  .maps-link:hover .maps-link__cta{text-decoration:underline}

  /* Horario en day-cards (misma tarjeta en ambas ciudades) */
  .city__sched{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,300px));gap:18px}
  .day-card{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:24px 22px}
  .day-card__name{font-size:1.05rem;text-transform:uppercase;letter-spacing:.08em;color:#fff;
    margin:0 0 14px;padding-bottom:12px;border-bottom:1px solid var(--line)}
  .day-card__list{list-style:none;margin:0;padding:0}
  .day-card__list li{display:grid;grid-template-columns:auto 1fr;gap:3px 12px;align-items:baseline;
    padding:10px 0;border-bottom:1px solid rgba(255,255,255,.06)}
  .day-card__list li:last-child{border-bottom:0}
  .day-card__time{color:var(--acc);font-weight:700;font-size:.85rem;font-variant-numeric:tabular-nums}
  .day-card__style{color:#fff;font-weight:600;font-size:.96rem}
  .day-card__level{grid-column:2;color:var(--muted);font-size:.74rem;text-transform:uppercase;letter-spacing:.05em}

  @media (max-width:820px){
    .city__lead{grid-template-columns:1fr;gap:26px}
    .city__lead--flip .city__media{order:0}
    .city__media{max-width:420px}
    .city__facts{grid-template-columns:1fr 1fr}
    .city__sched{grid-template-columns:1fr}
  }
</style>
