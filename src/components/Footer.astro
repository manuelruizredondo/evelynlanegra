---
import { site } from "../data/site";

const cols = [
  {
    title: "Navegación",
    links: [
      { label: "Home", href: "/" },
      { label: "Sobre Évelyn", href: "/curriculum/" },
      { label: "FOTOS Keeper", href: "/keeper-galeria/" },
      { label: "Blog", href: "/blog/" },
      { label: "Logotipos", href: "/logotipos/" },
    ],
  },
  {
    title: "Clases",
    links: [
      { label: "Escuela en Barcelona", href: "/clases-de-baile-en-barcelona/" },
      { label: "Escuela en Ibiza", href: "/clases-de-baile-en-ibiza/" },
      { label: "Clases Online", href: "/bachata-salsa-online-offline/" },
      { label: "Formación Bachata Dominicana", href: "/profesora-bachata-dominicana/" },
    ],
  },
  {
    title: "Eventos",
    links: [
      { label: "La Negra Dance Festival", href: site.festival, external: true },
      { label: "Keeper eventos 2025", href: "/keeper-galeria-eventos-2025/" },
      { label: "Keeper eventos 2026", href: "/keeper-galeria-eventos-2026/" },
    ],
  },
];
---
<footer class="site-footer">
  <div class="container site-footer__grid">
    <!-- Marca -->
    <div class="site-footer__brand">
      <img src="/img/2019/09/logo-lanegra.png" width="150" height="68" alt={site.name} />
      <p>{site.tagline}.</p>
      <div class="site-footer__social">
        <a href={site.instagram} target="_blank" rel="noopener">Instagram</a>
        <a href={site.spotify} target="_blank" rel="noopener">Spotify</a>
      </div>
    </div>

    <!-- Columnas de enlaces -->
    {cols.map((c) => (
      <nav class="site-footer__col" aria-label={c.title}>
        <h3>{c.title}</h3>
        <ul>
          {c.links.map((l) => (
            <li>
              <a href={l.href} {...(l.external ? { target: "_blank", rel: "noopener" } : {})}>{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    ))}

    <!-- Contacto -->
    <div class="site-footer__col">
      <h3>Contacto</h3>
      <ul>
        <li><a href={`tel:${site.phone.replace(/\s/g, "")}`}>T. {site.phoneShort}</a></li>
        <li><a href={site.whatsapp} target="_blank" rel="noopener">WhatsApp</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
      </ul>
    </div>
  </div>

  <div class="container site-footer__bar">
    <p>© {new Date().getFullYear()} {site.name}</p>
    <p class="site-footer__credit">Diseño y desarrollo a partir del sitio original</p>
  </div>
</footer>

<style>
  .site-footer{background:#0d0d0d;color:#9a9a9e;padding:60px 0 26px;border-top:1px solid rgba(255,255,255,.08)}
  .site-footer__grid{
    display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr 1fr;gap:40px;align-items:start;
  }
  .site-footer__brand img{height:52px;width:auto;margin-bottom:16px}
  .site-footer__brand p{margin:0 0 16px;font-size:.9rem;max-width:30ch;line-height:1.5}
  .site-footer__social{display:flex;gap:16px}
  .site-footer__social a{color:#fff;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em}
  .site-footer__social a:hover{color:var(--red-bright);text-decoration:none}

  .site-footer__col h3{
    color:#fff;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin:0 0 16px;
  }
  .site-footer__col ul{list-style:none;margin:0;padding:0}
  .site-footer__col li{margin-bottom:10px}
  .site-footer__col a{color:#bdbdc1;font-size:.88rem}
  .site-footer__col a:hover{color:#fff;text-decoration:none}

  .site-footer__bar{
    display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;
    margin-top:46px;padding-top:22px;border-top:1px solid rgba(255,255,255,.08);
    font-size:.78rem;color:#76767a;
  }
  .site-footer__bar p{margin:0}

  @media (max-width:900px){
    .site-footer__grid{grid-template-columns:1fr 1fr;gap:32px 28px}
    .site-footer__brand{grid-column:1 / -1}
  }
  @media (max-width:520px){
    .site-footer__grid{grid-template-columns:1fr 1fr}
    .site-footer__bar{justify-content:center;text-align:center}
  }
</style>
