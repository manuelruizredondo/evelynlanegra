---
import Base from "../layouts/Base.astro";
import ContactForm from "../components/ContactForm.astro";
import { site } from "../data/site";

type Clase = { hora: string; estilo: string; nivel?: string };

const dias: { dia: string; clases: Clase[] }[] = [
  {
    dia: "Lunes",
    clases: [
      { hora: "18:30", estilo: "Salsa", nivel: "medio" },
      { hora: "19:30", estilo: "Bachata", nivel: "medio/bajo" },
      { hora: "20:30", estilo: "Rueda de Casino", nivel: "medio/alto" },
      { hora: "21:30", estilo: "Salsa", nivel: "medio/alto" },
      { hora: "22:30", estilo: "Bachata", nivel: "medio" },
    ],
  },
  {
    dia: "Martes",
    clases: [
      { hora: "18:30", estilo: "Salsa", nivel: "avanzado" },
      { hora: "19:30", estilo: "Bachata", nivel: "medio" },
      { hora: "20:30", estilo: "Expresión Corporal" },
      { hora: "21:30", estilo: "Salsa", nivel: "medio/bajo" },
      { hora: "22:30", estilo: "Bachata", nivel: "medio/bajo" },
    ],
  },
  {
    dia: "Miércoles",
    clases: [
      { hora: "18:30", estilo: "Salsa", nivel: "básico II" },
      { hora: "19:30", estilo: "Bachata", nivel: "básico II" },
      { hora: "20:30", estilo: "Salsa", nivel: "desde cero" },
      { hora: "21:30", estilo: "Bachata", nivel: "desde cero" },
    ],
  },
];
---
<Base
  title="Clases de baile en Ibiza · Salsa y Bachata · La Negra"
  description="Aprende salsa y bachata en Ibiza. Curso noviembre-diciembre en Davinia Van Praag Dance Academy. Desde 30€/mes."
  transparentHeader={true}
>
  <section class="flyer-section">
    <div class="container">
      <article class="flyer" aria-label="Cartel de clases en Ibiza">
        <header class="flyer__head">
          <h1 class="flyer__title">SALSA BACHATA</h1>
          <p class="flyer__period">CURSO NOVIEMBRE-DICIEMBRE</p>
        </header>

        <div class="flyer__sched">
          {dias.map(({ dia, clases }) => (
            <div class="flyer__day">
              <h2 class="flyer__day-name">{dia}</h2>
              <ul class="flyer__classes">
                {clases.map((c) => (
                  <li>
                    <span class="flyer__time">{c.hora}h</span>
                    <span class="flyer__style">{c.estilo}</span>
                    {c.nivel && <span class="flyer__level">{c.nivel}</span>}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <footer class="flyer__foot">
          <div class="flyer__brand">
            <p class="flyer__academy">Davinia Van Praag Dance Academy</p>
            <p class="flyer__address">Calle Sa Real, 1 · Ibiza</p>
          </div>
          <div class="flyer__cta">
            <p class="flyer__price">DESDE 30€ MES</p>
            <p class="flyer__reserve">IMPRESCINDIBLE RESERVAR</p>
            <p class="flyer__phone">
              <a href={`tel:${site.phone.replace(/\s/g, "")}`}>{site.phone}</a>
              <a class="flyer__wa" href={site.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp">
                <img src="/img/2019/09/whatsUp200PX.png" width="48" height="48" alt="" />
              </a>
            </p>
            <p class="flyer__web">
              <a href="/">lanegrasalsa.com</a>
            </p>
          </div>
        </footer>
      </article>
    </div>
  </section>

  <ContactForm name="contacto-ibiza" title="Reserva tu plaza" note="Imprescindible reservar. Escríbeme y te confirmo horario y nivel." />
</Base>

<style>
  .flyer-section{padding:calc(var(--header-h) + 32px) 0 64px;background:#f0f0f0}

  .flyer{
    max-width:820px;margin:0 auto;padding:36px 32px 28px;border-radius:16px;
    background:linear-gradient(175deg,#f0a030 0%,#f7d94c 38%,#5ec8e8 100%);
    box-shadow:0 18px 50px rgba(0,0,0,.18);color:#1a1a1a;
  }

  .flyer__head{text-align:center;margin-bottom:28px}
  .flyer__title{
    margin:0;font-size:clamp(2rem,6vw,2.8rem);font-weight:900;letter-spacing:.06em;
    color:#fff;text-shadow:0 2px 8px rgba(0,0,0,.15);
  }
  .flyer__period{
    display:inline-block;margin:12px 0 0;padding:8px 22px;border-radius:999px;
    background:#f7e04b;color:#1e3a5f;font-weight:800;font-size:.85rem;letter-spacing:.04em;
  }

  .flyer__sched{
    display:grid;grid-template-columns:1fr 1fr;gap:18px 22px;margin-bottom:28px;
  }
  .flyer__day:last-child{grid-column:1}
  .flyer__day-name{
    margin:0 0 10px;padding:7px 16px;border-radius:999px;background:#f7e04b;
    color:#1e3a5f;font-size:.95rem;font-weight:800;text-transform:uppercase;text-align:center;
  }
  .flyer__classes{list-style:none;margin:0;padding:0}
  .flyer__classes li{
    display:flex;flex-wrap:wrap;align-items:baseline;gap:.35em;
    padding:7px 0;border-bottom:1px solid rgba(0,0,0,.08);font-size:.92rem;line-height:1.35;
  }
  .flyer__classes li:last-child{border-bottom:0}
  .flyer__time{font-weight:700;min-width:3.8em}
  .flyer__style{font-weight:600}
  .flyer__level{color:#2a4a7a;font-weight:800}

  .flyer__foot{
    display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-end;
    gap:20px;padding-top:22px;border-top:2px solid rgba(0,0,0,.1);
  }
  .flyer__academy{margin:0;font-weight:800;font-size:.82rem;letter-spacing:.03em;text-transform:uppercase}
  .flyer__address{margin:4px 0 0;font-size:.9rem;font-weight:600}
  .flyer__cta{text-align:right}
  .flyer__price{margin:0;font-size:1.35rem;font-weight:900;letter-spacing:.02em}
  .flyer__reserve{
    display:inline-block;margin:8px 0 10px;padding:6px 14px;border-radius:999px;
    background:#f7e04b;color:#1e3a5f;font-weight:800;font-size:.78rem;letter-spacing:.03em;
  }
  .flyer__phone{
    display:flex;align-items:center;justify-content:flex-end;gap:10px;
    margin:0;font-size:1.25rem;font-weight:800;
  }
  .flyer__phone a{color:inherit;text-decoration:none}
  .flyer__phone a:hover{text-decoration:underline}
  .flyer__wa{display:inline-flex;line-height:0}
  .flyer__web{margin:6px 0 0;font-size:.95rem;font-weight:700}
  .flyer__web a{color:#1e3a5f;text-decoration:none}
  .flyer__web a:hover{text-decoration:underline}

  @media (max-width:640px){
    .flyer{padding:28px 20px 22px}
    .flyer__sched{grid-template-columns:1fr}
    .flyer__day:last-child{grid-column:auto}
    .flyer__foot{flex-direction:column;align-items:center;text-align:center}
    .flyer__cta{text-align:center}
    .flyer__phone{justify-content:center}
  }
</style>
