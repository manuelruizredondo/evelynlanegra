---
import Base from "../../layouts/Base.astro";
import Faq from "../../components/Faq.astro";
import { site } from "../../data/site";

const faqs = [
  { q: "Devo venire in coppia?", a: "No. Durante le lezioni si ruota, quindi puoi iscriverti da solo o da sola senza problemi." },
  { q: "Si può iniziare da zero?", a: "Sì. Ci sono gruppi e contenuti pensati per iniziare da zero; ti accompagno dal passo e dal conteggio di base." },
  { q: "Dove si tengono le lezioni in presenza?", a: `A Barcellona (BS Dance Center) e Ibiza (Davinia Van Praag Dance Academy). Puoi vedere gli orari in <a href="/it/clases-presenciales/">lezioni in presenza</a>.` },
  { q: "Le lezioni online restano registrate?", a: "Sì. Le sessioni in diretta su Zoom vengono registrate così puoi rivederle al tuo ritmo quando vuoi." },
  { q: "Il master abilita a insegnare bachata tradizionale?", a: `È una formazione per insegnanti con metodologia propria e diploma accreditato. Trovi il programma nella <a href="/it/profesora-bachata-dominicana/">pagina del master</a>.` },
];

const eventos = [
  { img: "/img/campeonato.webp", chip: "Calpe · Alicante · 21–25 ott", t: "Il campionato mondiale",
    d: "Il Mundial de Pasos Libres di Salsa: la competizione pioniera al mondo, creata da La Negra. Ballerini da tutto il pianeta su un'unica pista.",
    href: site.festival, external: true, cta: "Prenota il tuo posto" },
  { img: "/img/crucero.jpg", chip: "Spagna · Italia · Francia · 1–8 nov", t: "Crociera del ballo",
    d: "Più di un viaggio — giorni di salsa, bachata e buona compagnia a bordo. Lezioni, sessioni e mare aperto.",
    href: site.whatsapp, external: true, cta: "Prenota il tuo posto" },
];

const presenciales = [
  { img: "/img/2024/12/clases-bcn-korke-y-judith-576x1024.jpeg", chip: "Lezioni regolari · giovedì", t: "Barcellona",
    d: "Bachata tradizionale al BS Dance Center. Lezioni regolari in diretta tutti i giovedì.",
    href: "/it/clases-presenciales/#barcelona", cta: "Vedi le lezioni" },
  { img: "/img/2025/11/IBIZA-clases-nov-dic25-con-horarios-819x1024.png", chip: "Lezioni regolari · tutto l'anno", t: "Ibiza",
    d: "Salsa e bachata alla Davinia Van Praag Dance Academy. Corsi regolari per trimestre.",
    href: "/it/clases-presenciales/#ibiza", cta: "Vedi le lezioni" },
];

const online = [
  { img: "/img/2021/10/web-ensenanza-de-la-bachata-libro-1024x1024.jpg", chip: "Programma per insegnanti", t: "Master in Bachata Tradizionale",
    d: "Formazione strutturata per insegnanti: moduli I, II e III, metodologia propria e il titolo di riferimento nella bachata dominicana.",
    href: "/it/profesora-bachata-dominicana/", cta: "Vedi il programma" },
  { img: "/img/2024/12/los-jueves-zoom-1080X1080-1024x1024.png", chip: "In diretta · Zoom", t: "Lezioni online",
    d: "Bachata e salsa in diretta su Zoom. Le lezioni restano registrate per te.",
    href: "/it/bachata-salsa-online-offline/", cta: "Inizia" },
];

const worldtour = [
  { mes: "Luglio", items: [
    { place: "Giappone · Tokyo", date: "2-5", event: "Bachata Media Japón Festival" },
    { place: "Corea · Jeju Island", date: "10-12", event: "K-Sensual 10th Anniversary" },
    { place: "Gran Canaria", date: "17-19", event: "Teacher Training e Intensivo Bachata Tradizionale I" },
    { place: "Valencia", date: "26-27", event: "Teacher Training Bachata Tradizionale (I, II e III)" },
    { place: "Italia · Roma", date: "31-2", event: "Meeteach Bachata Weekend" },
  ]},
  { mes: "Agosto", items: [
    { place: "Italia · Roma", date: "1 e 2", event: "Meeteach Bachata Weekend" },
    { place: "Romania · Bucarest", date: "7-9", event: "Formazione e Intensivo Bachata Tradizionale" },
    { place: "Messico Tour", date: "19-30", event: "Varie città" },
  ]},
  { mes: "Settembre", items: [
    { place: "Taiwan · Taipei", date: "5 e 6", event: "Freedom Bachata Weekender" },
    { place: "Siviglia", date: "10-13", event: "DyD Be Unlike" },
    { place: "Madrid", date: "17-20", event: "Vacílalo Madrid Congress" },
    { place: "Quito · Ecuador", date: "24-28", event: "República Bachata" },
  ]},
  { mes: "Ottobre", items: [
    { place: "Norvegia · Oslo", date: "2-4", event: "Intensivo Bachata Tradizionale" },
    { place: "Ibiza", date: "4-9", event: "Dance4two Dance Holiday" },
    { place: "Barcellona", date: "9-11", event: "Teacher Training Course by Korke y Judith" },
    { place: "Calpe · Alicante", date: "21-25", event: "XV Mundial de Pasos Libres" },
    { place: "Santa Susana", date: "30-31", event: "El Bloque Bachatero" },
  ]},
  { mes: "Novembre", items: [
    { place: "Spagna · Italia · Francia", date: "1-8", event: "Crucero del Baile · Edición Delux Otoño" },
    { place: "Italia", date: "14 e 15", event: "Formazione e intensivi" },
    { place: "Polonia", date: "19-22", event: "Bachateando Afrolatin Dance Festival" },
    { place: "Malaysia · Kuala Lumpur", date: "27-29", event: "World Bachata Festival Kuala Lumpur" },
  ]},
  { mes: "Dicembre", items: [
    { place: "Cina", date: "4-6", event: "Bachata Congress" },
    { place: "Italia · Treviso", date: "11-13", event: "Intensivo Bachata Tradizionale #Sinbarrio" },
    { place: "Olanda", date: "18-20", event: "Biezenmortel Christmas Edition" },
  ]},
];
---
<Base
  title="Évelyn «La Negra» — Insegnante & DJ di salsa e bachata dominicana"
  description="Évelyn «La Negra»: insegnante e DJ di ritmi latini dal 1997. Salsa e bachata dominicana a Barcellona, Ibiza e online."
  transparentHeader={true}
  preloadImage="/img/evelynbn.png"
>
  <div class="ln">

    <!-- HERO -->
    <header class="ln-hero">
      <img class="ln-hero__img" src="/img/evelynbn.png" alt="Évelyn «La Negra» che balla bachata dominicana"
        width="1830" height="1025" fetchpriority="high" decoding="async" />
      <h1 class="ln-hero__name">
        <span class="he-name">Évelyn</span>
        <strong class="he-laneg">La Negra</strong>
        <span class="he-disc">Bachata Tradizionale</span>
      </h1>
      <div class="ln-hero__bottom container">
        <p class="ln-hero__role">Insegnante &amp; DJ · Salsa · Bachata Dominicana</p>
        <div class="ln-hero__cta">
          <a class="btn btn--red btn--lg" href={site.whatsapp} target="_blank" rel="noopener">Vieni a ballare</a>
          <a class="btn btn--ghost btn--lg" href="/it/curriculum/">Scopri chi è</a>
        </div>
      </div>
    </header>

    <!-- FRANJA DE CREDIBILIDAD -->
    <section class="stats" aria-label="La Negra in cifre">
      <div class="container stats__grid">
        <div class="stat"><span class="stat__n">+25</span><span class="stat__l">anni in pista</span></div>
        <div class="stat"><span class="stat__n">40+</span><span class="stat__l">paesi in tour</span></div>
        <div class="stat"><span class="stat__n">2010</span><span class="stat__l">ha creato il Mundial de Pasos Libres</span></div>
        <div class="stat"><span class="stat__n">∞</span><span class="stat__l">maestra di maestri</span></div>
      </div>
    </section>

    <!-- 1 · EVENTOS -->
    <section class="ev" id="eventos">
      <div class="container">
        <h2 class="ev__title">Prossimi eventi</h2>
        <div class="ev__grid">
          {eventos.map((c) => (
            <a class="evcard" href={c.href} {...(c.external ? { target: "_blank", rel: "noopener" } : {})}>
              <img class="evcard__img" src={c.img} alt={c.t} loading="lazy" />
              <span class="evcard__chip">{c.chip}</span>
              <div class="evcard__body">
                <h3>{c.t}</h3>
                <p>{c.d}</p>
                <span class="evcard__link">{c.cta} <span class="arrow">→</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 2 · FORMACIÓN PRESENCIAL -->
    <section class="ev" id="formacion-presencial">
      <div class="container">
        <h2 class="ev__title">Formazione in presenza</h2>
        <div class="ev__grid">
          {presenciales.map((c) => (
            <a class="evcard" href={c.href}>
              <img class="evcard__img" src={c.img} alt={c.t} loading="lazy" />
              <span class="evcard__chip">{c.chip}</span>
              <div class="evcard__body">
                <h3>{c.t}</h3>
                <p>{c.d}</p>
                <span class="evcard__link">{c.cta} <span class="arrow">→</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 3 · FORMACIÓN ONLINE & MÁSTER -->
    <section class="ev" id="formacion-online">
      <div class="container">
        <h2 class="ev__title">Formazione online &amp; Master</h2>
        <div class="ev__grid">
          {online.map((c) => (
            <a class="evcard" href={c.href}>
              <img class="evcard__img" src={c.img} alt={c.t} loading="lazy" />
              <span class="evcard__chip">{c.chip}</span>
              <div class="evcard__body">
                <h3>{c.t}</h3>
                <p>{c.d}</p>
                <span class="evcard__link">{c.cta} <span class="arrow">→</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 4 · WORLD TOUR -->
    <section class="tour" id="world-tour">
      <div class="container">
        <h2 class="ev__title">World Tour 2026</h2>
        <p class="tour__sub">Rotta La Negra · lug – dic 2026. Trovami in tutto il mondo.</p>
      </div>
      <div class="tour__cols">
        {worldtour.map((m) => (
          <div class="tour__month">
            <h3 class="tour__mes">{m.mes}</h3>
            {m.items.map((it) => (
              <div class="tour__item">
                <p class="tour__place">{it.place} <span class="tour__date">{it.date}</span></p>
                <p class="tour__event">{it.event}</p>
              </div>
            ))}
          </div>
        ))}
      </div>
      <div class="container">
        <p class="tour__note">Domeniche · DJ residente KEEPER Ibiza &nbsp;·&nbsp; Lezioni regolari: Ibiza (lun–mer) · Barcellona BS Dance Center (giovedì)</p>
        <p class="tour__cta"><a class="btn btn--red btn--lg" href={site.whatsapp} target="_blank" rel="noopener">Prossime date</a></p>
      </div>
    </section>

    <!-- 5 · TIENDA -->
    <section class="ln-merch" id="tienda">
      <div class="container ln-merch__inner">
        <div>
          <p class="kick">Shop</p>
          <h2 class="ln-h2">Magliette ufficiali</h2>
          <p class="ln-merch__lead">Porta con te il Metodo Bachata Tradizionale. Usa il codice
            <strong>EVELYN</strong> e ottieni il 10% di sconto.</p>
          <a class="btn btn--red btn--lg" href={site.shop} target="_blank" rel="noopener">Vai allo shop</a>
        </div>
        <div class="ln-merch__imgs">
          <img src="/img/2021/02/CAMISETA-BACHATA-TRADICIONAL-CHICAS.jpg" alt="Maglietta donna" loading="lazy" />
          <img src="/img/2021/02/CAMISETA-BACHATA-TRADICIONAL-CHICOS.jpg" alt="Maglietta uomo" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- 5b · FAQ -->
    <Faq kicker="Dubbi frequenti" title="Domande frequenti" items={faqs} />

    <!-- 6 · CONTACTA -->
    <section class="ln-social" id="contacta">
      <div class="container ln-social__inner">
        <div>
          <p class="kick">Contatti</p>
          <h2 class="ln-h2">Parliamone?</h2>
          <div class="ln-social__links">
            <a href={site.whatsapp} target="_blank" rel="noopener">WhatsApp</a>
            <a href={`tel:${site.phone.replace(/\s/g, "")}`}>Telefono</a>
            <a href={`mailto:${site.email}`}>Email</a>
          </div>
          <div class="ln-social__links ln-social__links--alt">
            <a href={site.instagram} target="_blank" rel="noopener">Instagram</a>
            <a href={site.spotify} target="_blank" rel="noopener">Spotify</a>
            <a href={site.festival} target="_blank" rel="noopener">LaNegra World Championship</a>
          </div>
        </div>
        <form class="ln-news" name="newsletter-it" method="POST" action="/it/gracias/" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="newsletter-it" />
          <p hidden><label>No rellenar: <input name="bot-field" /></label></p>
          <label class="ln-news__label" for="nl-email">Ricevi date e novità</label>
          <div class="ln-news__row">
            <input id="nl-email" type="email" name="email" placeholder="tua@email.com" required />
            <button class="btn btn--red" type="submit">Iscrivimi</button>
          </div>
          <label class="ln-news__consent">
            <input type="checkbox" name="consentimiento" value="si" required />
            <span>Accetto l'<a href="/it/privacidad/" target="_blank" rel="noopener">informativa sulla privacy</a>.</span>
          </label>
        </form>
      </div>
    </section>

  </div>
</Base>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Event",
      name: "Mundial de Pasos Libres de Salsa",
      description: "La competizione pioniera di salsa al mondo, creata da La Negra.",
      startDate: "2026-10-21",
      endDate: "2026-10-25",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      location: { "@type": "Place", name: "Calpe", address: "Calpe, Alicante, Spagna" },
      organizer: { "@type": "Person", name: "Évelyn «La Negra»" },
      url: site.festival,
    },
    {
      "@type": "Event",
      name: "Crucero del Baile · Edición Delux Otoño",
      description: "Giorni di salsa, bachata e buona compagnia a bordo: lezioni, sessioni e mare aperto.",
      startDate: "2026-11-01",
      endDate: "2026-11-08",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      location: { "@type": "Place", name: "Mediterraneo", address: "Spagna · Italia · Francia" },
      organizer: { "@type": "Person", name: "Évelyn «La Negra»" },
    },
  ],
})} />

<style is:global>
  body:has(.ln){background:#0a0a0a;color:#c9c9cc}
</style>

<style>
  .ln{background:#0a0a0a;color:#c9c9cc;--acc:#ce0306;--acc2:#ffc400;--muted:#c9c9cc;--line:rgba(255,255,255,.1);
    font-family:"Mona Sans","Lato",-apple-system,sans-serif}
  .ln :global(h2),.ln :global(h3){color:#fff;font-family:"Mona Sans","Lato",sans-serif}

  /* Franja de credibilidad */
  .stats{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:#0d0d0d}
  .stats__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;padding:36px 20px;text-align:center}
  .stat{display:flex;flex-direction:column;gap:6px}
  .stat__n{font-family:"Mona Sans","Lato",sans-serif;font-weight:900;font-variation-settings:"wght" 900,"wdth" 120;
    font-size:clamp(2rem,5vw,3.2rem);line-height:1;color:#fff}
  .stat__l{font-size:.82rem;letter-spacing:.04em;color:var(--muted);text-transform:uppercase}
  .stat:nth-child(3) .stat__n{color:var(--acc)}
  @media (max-width:680px){.stats__grid{grid-template-columns:1fr 1fr;gap:26px 12px}}

  /* Consentimiento newsletter */
  .ln-news__consent{display:flex;align-items:flex-start;gap:9px;margin-top:12px;font-size:.8rem;color:var(--muted)}
  .ln-news__consent input{width:auto;margin-top:2px;accent-color:var(--acc)}
  .ln-news__consent a{color:var(--acc)}

  /* Display gigante estilo Lando: Mona Sans pesada y expandida */
  .ln-h2,.ln-quote,.ln-journey__text,.ln-hero__name strong,.ln-split__col h3,.ln-tag__title{
    font-stretch:118%;font-variation-settings:"wght" 850,"wdth" 118}
  .ln-hero__name strong,.ln-tag__title{font-variation-settings:"wght" 900,"wdth" 122}
  .kick{font-size:.72rem;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:var(--acc);margin:0 0 14px;display:flex;align-items:center;gap:10px}
  .ln-h2{font-size:clamp(1.9rem,4.6vw,3.2rem);font-weight:800;text-transform:uppercase;letter-spacing:-.01em;line-height:1;margin:0}
  .hl{color:var(--acc)}
  .ln-sign{font-family:var(--script);text-transform:none;color:var(--acc);font-weight:700}

  /* HERO */
  .ln-hero{position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:space-between;overflow:hidden;background:#0a0a0a}
  .ln-hero__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 28%;
    opacity:.95;animation:heroReveal 1.8s ease both}
  @keyframes heroReveal{from{opacity:0;transform:scale(0.92)}to{opacity:.95;transform:scale(1)}}
  @media (prefers-reduced-motion:reduce){.ln-hero__img{animation:none;opacity:.95}}
  .ln-hero::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.6),rgba(0,0,0,.15) 30%,rgba(0,0,0,.35) 70%,#0a0a0a 100%)}
  .ln-hero__top{position:relative;z-index:2;padding-top:96px}
  .chip{display:inline-flex;align-items:center;gap:9px;background:rgba(0,0,0,.5);border:1px solid var(--line);
    padding:8px 16px;border-radius:999px;font-size:.74rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fff}
  .chip .dot{width:8px;height:8px;border-radius:50%;background:var(--acc2);box-shadow:0 0 0 0 rgba(255,196,0,.6)}
  .ln-hero__name{position:relative;z-index:2;text-align:center;margin:auto 0;line-height:1;padding-inline:18px;transform:translateY(12vh)}
  .ln-hero__name .he-name{display:block;font-family:var(--script);text-transform:none;font-weight:400;
    font-size:clamp(2.2rem,6vw,4.2rem);color:#fff;opacity:1;letter-spacing:0;line-height:1}
  .ln-hero__name .he-laneg{display:block;font-family:"Mona Sans","Lato",sans-serif;
    font-size:clamp(3.5rem,16vw,11rem);font-weight:900;letter-spacing:-.02em;text-transform:uppercase;
    color:#fff;line-height:.86;font-stretch:122%;font-variation-settings:"wght" 900,"wdth" 122;margin:-.03em 0}
  .ln-hero__name .he-disc{display:block;font-family:var(--script);text-transform:none;font-weight:400;
    font-size:clamp(1.4rem,6.5vw,4.8rem);color:var(--acc);opacity:1;letter-spacing:0;line-height:1;max-width:100%}
  .ln-hero__bottom{position:relative;z-index:2;padding-bottom:40px;text-align:center}
  .ln-hero__role{font-size:1rem;letter-spacing:.16em;text-transform:uppercase;color:#fff;margin:0 0 20px}
  .ln-hero__cta{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:22px}
  .ln-hero__next{margin:12px 0 0}

  /* MANIFIESTO */
  .ln-manifesto{padding:110px 0 60px;border-top:1px solid var(--line)}
  .ln-manifesto .kick{justify-content:center;margin-bottom:18px}
  .ln-quote{font-size:clamp(1.7rem,4.4vw,3rem);font-weight:800;line-height:1.12;max-width:20ch;margin:0 auto;text-align:center;text-transform:uppercase;letter-spacing:-.01em}
  .ln-quote em{font-style:normal;color:var(--acc)}
  .ln-quote__sub{color:var(--muted);font-size:1.05rem;margin:22px auto 0;max-width:46ch;text-align:center}
  .hscroll{display:flex;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;padding:46px 24px 14px;scrollbar-width:thin}
  .hscroll__item{flex:0 0 auto;scroll-snap-align:center}
  .hscroll__item img{height:58vh;width:auto;border-radius:14px;object-fit:cover}

  /* JOURNEY */
  .ln-journey{padding:80px 0;border-top:1px solid var(--line)}
  .ln-journey__text{font-size:clamp(1.3rem,3vw,2rem);font-weight:600;line-height:1.4;max-width:24ch;color:#fff;margin:0}
  .ln-journey__text strong{color:var(--acc)}
  .ln-journey__note{color:var(--muted);font-size:1.05rem;line-height:1.6;max-width:54ch;margin:20px 0 0}

  /* SPLIT */
  .ln-split{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--line)}
  .ln-split__col{padding:80px 6vw;text-decoration:none;color:#c9c9cc;transition:background .25s;border-right:1px solid var(--line)}
  .ln-split__col--alt{border-right:0}
  .ln-split__col:hover{background:#121214;text-decoration:none}
  .ln-split__num{font-size:.9rem;font-weight:800;color:var(--acc);letter-spacing:.1em}
  .ln-split__col h3{font-size:clamp(1.8rem,4vw,2.8rem);text-transform:uppercase;font-weight:900;margin:12px 0 12px}
  .ln-split__col p{color:var(--muted);max-width:36ch;margin:0 0 18px}
  .ln-split__go{color:var(--acc);font-weight:700}

  /* SHOWCASE */
  .ln-show{padding:96px 0;border-top:1px solid var(--line)}
  .ln-show__head{margin-bottom:40px}
  .ln-show__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .tile{display:block;text-decoration:none;color:#fff;group:tile}
  .tile__media{aspect-ratio:3/4;overflow:hidden;border-radius:14px;background:#0f0f10;border:1px solid var(--line)}
  .tile__media img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease;filter:grayscale(.2)}
  .tile:hover .tile__media img{transform:scale(1.06);filter:grayscale(0)}
  .tile__k{display:inline-block;margin:14px 0 4px;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--acc)}
  .tile h3{font-size:1.2rem;text-transform:uppercase;font-weight:800;margin:0}

  /* MERCH */
  .ln-merch{padding:96px 0;border-top:1px solid var(--line);background:#0f0f10}
  .ln-merch__inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
