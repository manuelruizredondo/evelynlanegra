---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";
const covers = [
  "/img/2023/08/top10-musica-verano-salsa-bachata-merengue-260x300.jpg",
  "/img/2022/05/top10-musica-mayo-salsa-bachata-merengue-260x300.jpg",
  "/img/2022/04/top10-musica-abril-salsa-bachata-merengue-260x300.jpg",
  "/img/2022/03/top10-musica-marzo-salsa-bachata-merengue-260x300.jpg",
  "/img/2022/02/top10-musica-febrero-salsa-bachata-merengue-260x300.jpg",
  "/img/2022/01/top10-musica-enero-salsa-bachata-merengue-260x300.jpg",
  "/img/2021/12/top10-musica-diciembre-salsa-bachata-merengue-260x300.jpg",
  "/img/2021/11/top10-musica-noviembre-salsa-bachata-merengue-260x300.jpg",
  "/img/2021/10/top10-musica-octubre-salsa-bachata-merengue-2-260x300.jpg",
  "/img/2021/09/top10-musica-septiembre-salsa-bachata-merengue-1-260x300.jpg",
];
---
<Base title="Blog · TOP 10 Salsa, Bachata y Merengue · La Negra" description="El blog de La Negra: el TOP 10 mensual de música salsa, bachata y merengue.">
  <section class="gallery-hero">
    <div class="container text-center">
      <p class="eyebrow" style="color:var(--red-bright)">Blog</p>
      <h1>TOP 10 · Salsa, Bachata &amp; Merengue</h1>
      <p style="opacity:.85;max-width:560px;margin:10px auto 0">Cada mes, mi selección de los temas más sonados para bailar.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="img-grid">
        {covers.map((src) => <img src={src} alt="TOP 10 música salsa, bachata y merengue" loading="lazy" />)}
      </div>
      <p class="text-center" style="margin-top:30px">
        <a class="btn btn--red btn--lg" href={site.spotify} target="_blank" rel="noopener">Escúchalo en Spotify</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .gallery-hero{background:#111;color:#fff;padding:90px 0 50px}
  .gallery-hero h1{color:#fff;font-size:2.3rem}
</style>
