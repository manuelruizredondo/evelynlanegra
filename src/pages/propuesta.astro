---
import Base from "../layouts/Base.astro";
import { site } from "../data/site";

const areas = [
  { n: "01", t: "Bachata Dominicana", d: "El estilo tradicional, desde la raíz: musicalidad, pisada y sabor auténtico." },
  { n: "02", t: "Salsa Cubana", d: "Casino, rueda y movimiento corporal con base sólida y mucha energía." },
  { n: "03", t: "DJ · Ritmos Latinos", d: "Sesiones que llenan pistas. Residente de las salas más salseras del país." },
  { n: "04", t: "Formación de profesores", d: "Programa de enseñanza de bachata dominicana. Maestra de maestros." },
  { n: "05", t: "Producción de eventos", d: "Congresos, campeonatos y sesiones. De la idea al escenario." },
  { n: "06", t: "Animación y espectáculo", d: "Carisma y fuerza sobre el escenario. La fiesta no para." },
];

const timeline = [
  { y: "1997", t: "Empieza a enseñar a bailar", d: "Llega a Barcelona y comienza a impartir clases de salsa y ritmos latinos." },
  { y: "2003", t: "La Vanguardia · Revista Salseros", d: "7 años como redactora y productora digital; después, Directora de Contenidos de Revista Salseros." },
  { y: "2010", t: "Campeonato Int. de Pasos Libres", d: "Crea en Barcelona el campeonato pionero en el mundo en su especialidad." },
  { y: "Hoy", t: "Antilla · Cala Bassa · Festival", d: "DJ residente de Antilla Latin Club, sesión de Cala Bassa (Ibiza) y La Negra Salsa Festival." },
];

const stats = [
  { k: "+25", v: "años enseñando" },
  { k: "2", v: "escuelas: Barcelona e Ibiza" },
  { k: "+10.000", v: "alumnos formados" },
  { k: "1", v: "campeonato internacional" },
];

const lugares = [
  { t: "Barcelona", d: "BS Dance Center · Bachata Tradicional, los jueves.", href: "/clases-de-baile-en-barcelona/" },
  { t: "Ibiza", d: "Davinia Van Praag Dance Academy · Salsa y Bachata.", href: "/clases-de-baile-en-ibiza/" },
  { t: "Online", d: "Clases en directo por Zoom. Se quedan grabadas.", href: "/bachata-salsa-online-offline/" },
];
---
<Base
  title="Évelyn «La Negra» — Profesora y DJ de ritmos latinos"
  description="Évelyn «La Negra»: 25+ años convirtiendo el baile en cultura, comunidad y pasión. Salsa y bachata dominicana en Barcelona, Ibiza y online."
  transparentHeader={true}
>
  <div class="px">

    <!-- HERO -->
    <header class="hero">
      <div class="hero__glow" aria-hidden="true"></div>
      <img class="hero__img" src="/img/2019/09/LA-NEGRA-SALSA-BACHATA-KIZOMBA-EVELYN-VIANA-2.jpg" alt="Évelyn La Negra" />
      <div class="hero__inner container">
        <p class="kicker">Profesora · DJ · Productora</p>
        <h1 class="hero__title">
          Soy Évelyn, <span class="script">«La Negra».</span><br>
          Convierto el baile en <em>cultura</em>, <em>comunidad</em> y <em>pasión</em>.
        </h1>
        <p class="hero__lead">
          <strong>+25 años</strong> de salsa y bachata dominicana — entre Barcelona, Ibiza y el mundo entero.
        </p>
        <div class="hero__cta">
          <a class="btn btn--red btn--lg" href="/curriculum/">Conóceme</a>
          <a class="btn btn--ghost btn--lg" href={site.whatsapp} target="_blank" rel="noopener">Ven a bailar</a>
        </div>
      </div>
      <a class="hero__scroll" href="#areas" aria-label="Bajar">↓</a>
    </header>

    <!-- ÁREAS -->
    <section class="band" id="areas">
      <div class="container">
        <div class="band__head">
          <p class="kicker">Áreas de especialización</p>
          <h2 class="display">Lo que enseño, <span class="hl">lo vivo</span>.</h2>
        </div>
        <div class="grid">
          {areas.map((a) => (
            <article class="cardx">
              <span class="cardx__n">{a.n}</span>
              <h3>{a.t}</h3>
              <p>{a.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- BIO -->
    <section class="band band--soft">
      <div class="container bio">
        <div class="bio__media">
          <img src="/img/2020/11/LA-NEGRA-SALSA-BACHATA-KIZOMBA-EVELYN-VIANA-blanco.jpg" alt="Évelyn Viana Lovera" />
        </div>
        <div class="bio__body">
          <p class="kicker">Sobre Évelyn</p>
          <h2 class="display">Dos décadas construyendo la <span class="hl">mejor comunidad bailonga</span>.</h2>
          <p>Periodista venezolana, productora, DJ y profesora de salsa y ritmos latinos radicada en
            Barcelona desde 1997. Especializada en salsa cubana y bachata dominicana, ha sabido
            combinar el trabajo intelectual con las clases, los eventos y el escenario.</p>
          <div class="stats">
            {stats.map((s) => (
              <div class="stat"><span class="stat__k">{s.k}</span><span class="stat__v">{s.v}</span></div>
            ))}
          </div>
          <a class="btn btn--red" href="/curriculum/">Mi trayectoria completa</a>
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="band">
      <div class="container">
        <div class="band__head">
          <p class="kicker">Trayectoria</p>
          <h2 class="display">Dos décadas. <span class="hl">Una dirección.</span></h2>
        </div>
        <ol class="tl">
          {timeline.map((e) => (
            <li class="tl__row">
              <span class="tl__y">{e.y}</span>
              <div class="tl__c">
                <h3>{e.t}</h3>
                <p>{e.d}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- KEEPER BAND -->
    <section class="keeper">
      <img class="keeper__bg" src="/img/2026/04/03_mayo_26_keeper_DJLISSJ.jpg" alt="" aria-hidden="true" />
      <div class="keeper__inner container">
        <p class="kicker">Keeper · Salsa &amp; Bachata Sunday</p>
        <h2 class="display">La sesión más salsera, <span class="hl">en imágenes</span>.</h2>
        <p class="keeper__lead">Cientos de fotos de cada evento. Revive la pista.</p>
        <a class="btn btn--red btn--lg" href="/keeper-galeria/">Ver las galerías</a>
      </div>
    </section>

    <!-- DÓNDE -->
    <section class="band band--soft">
      <div class="container">
        <div class="band__head">
          <p class="kicker">¿Dónde podrás encontrarme?</p>
          <h2 class="display">Tres formas de <span class="hl">venir a bailar</span>.</h2>
        </div>
        <div class="places">
          {lugares.map((l) => (
            <a class="place" href={l.href}>
              <h3>{l.t}</h3>
              <p>{l.d}</p>
              <span class="place__go">Ver clases →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </div>
</Base>

<style is:global>
  /* La página vive en oscuro */
  body:has(.px){background:#0a0a0a;color:#e9e9ea}
</style>

<style>
  .px{background:#0a0a0a;color:#e9e9ea;--accent:#ff2e4d;--accent2:#ff7a18;--muted:#9a9a9e;--line:rgba(255,255,255,.1)}
  .px :global(h1),.px :global(h2),.px :global(h3){color:#fff}
  .kicker{font-family:var(--font);font-size:.72rem;font-weight:700;letter-spacing:.22em;
    text-transform:uppercase;color:var(--accent);margin:0 0 18px;display:flex;align-items:center;gap:10px}
  .kicker::before{content:"";width:26px;height:2px;background:var(--accent)}
  .display{font-size:clamp(1.9rem,4.4vw,3.2rem);font-weight:800;line-height:1.05;letter-spacing:-.01em;margin:0}
  .hl{color:var(--accent)}
  .script{font-family:var(--script);font-weight:700;color:var(--accent)}

  /* HERO */
  .hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;background:#000}
  .hero__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:12% center;opacity:.92}
  .hero__glow{position:absolute;top:-30%;right:-10%;width:80vw;height:80vw;pointer-events:none;
    background:radial-gradient(circle,rgba(255,122,24,.5) 0%,rgba(255,46,77,.35) 35%,transparent 65%);
    filter:blur(20px);mix-blend-mode:screen}
  .hero::after{content:"";position:absolute;inset:0;
    background:linear-gradient(90deg,rgba(0,0,0,.5) 0%,rgba(0,0,0,.18) 26%,rgba(0,0,0,.74) 56%,#0a0a0a 100%)}
  .hero__inner{position:relative;z-index:2;margin-left:auto;width:min(620px,100%);
    padding-top:120px;padding-bottom:60px}
  .hero__title{font-size:clamp(2.1rem,5vw,3.5rem);font-weight:800;line-height:1.08;letter-spacing:-.015em;margin:0 0 22px}
  .hero__title em{font-style:normal;color:var(--accent)}
  .hero__lead{font-size:1.15rem;color:#d8d8da;max-width:46ch;margin:0 0 30px}
  .hero__lead strong{color:#fff}
  .hero__cta{display:flex;gap:14px;flex-wrap:wrap}
  .hero__scroll{position:absolute;left:50%;bottom:26px;transform:translateX(-50%);z-index:2;
    color:#fff;font-size:1.4rem;opacity:.6;text-decoration:none;animation:bob 1.8s ease-in-out infinite}
  @keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,8px)}}

  /* BANDS */
  .band{padding:96px 0;border-top:1px solid var(--line)}
  .band--soft{background:#0f0f10}
  .band__head{max-width:720px;margin:0 0 48px}

  /* GRID DE ÁREAS */
  .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);
    border:1px solid var(--line)}
  .cardx{background:#0a0a0a;padding:34px 28px;transition:background .25s ease}
  .cardx:hover{background:#141416}
  .cardx__n{font-family:var(--font);font-size:.8rem;font-weight:800;color:var(--accent);letter-spacing:.1em}
  .cardx h3{font-size:1.25rem;margin:14px 0 8px}
  .cardx p{color:var(--muted);margin:0;font-size:.95rem}

  /* BIO */
  .bio{display:grid;grid-template-columns:0.85fr 1fr;gap:56px;align-items:center}
  .bio__media img{width:100%;border-radius:14px;border:1px solid var(--line);
    box-shadow:0 30px 70px rgba(0,0,0,.5)}
  .bio__body p{color:#c9c9cc;margin:18px 0 0}
  .stats{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;margin:30px 0}
  .stat{border-left:2px solid var(--accent);padding-left:14px}
  .stat__k{display:block;font-size:1.9rem;font-weight:800;color:#fff;line-height:1}
  .stat__v{color:var(--muted);font-size:.85rem}

  /* TIMELINE */
  .tl{list-style:none;margin:0;padding:0;border-top:1px solid var(--line)}
  .tl__row{display:grid;grid-template-columns:160px 1fr;gap:30px;padding:30px 0;border-bottom:1px solid var(--line);
    transition:background .2s}
  .tl__row:hover{background:#101012}
  .tl__y{font-family:var(--font);font-weight:800;font-size:1.4rem;color:var(--accent)}
  .tl__c h3{margin:0 0 6px;font-size:1.2rem}
  .tl__c p{margin:0;color:var(--muted)}

  /* KEEPER */
  .keeper{position:relative;padding:120px 0;overflow:hidden;text-align:center;border-top:1px solid var(--line)}
  .keeper__bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.32}
  .keeper::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at center,transparent,#0a0a0a 78%)}
  .keeper__inner{position:relative;z-index:2;max-width:680px}
  .keeper__inner .kicker{justify-content:center}
  .keeper__lead{color:#d0d0d2;margin:14px 0 26px}

  /* PLACES */
  .places{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .place{display:block;background:#0a0a0a;border:1px solid var(--line);border-radius:14px;padding:30px;
    text-decoration:none;transition:transform .2s,border-color .2s}
  .place:hover{transform:translateY(-4px);border-color:var(--accent);text-decoration:none}
  .place h3{margin:0 0 10px;font-size:1.4rem}
  .place p{color:var(--muted);margin:0 0 18px}
  .place__go{color:var(--accent);font-weight:700;font-size:.9rem}

  @media (max-width:820px){
    .grid{grid-template-columns:1fr 1fr}
    .bio{grid-template-columns:1fr;gap:28px}
    .bio__media{max-width:380px}
    .tl__row{grid-template-columns:80px 1fr;gap:16px}
    .places{grid-template-columns:1fr}
    .hero__inner{margin-inline:auto}
  }
  @media (max-width:560px){
    .grid{grid-template-columns:1fr}
    .stats{grid-template-columns:1fr}
  }
</style>
